-- shacl_validation.sql — SHACL Core validation tests
--
-- Covers:
--   1. load_shacl() — parse and store shapes
--   2. list_shapes() — enumerate stored shapes
--   3. validate() — offline validation report
--   4. drop_shape() — remove a shape
--   5. sync mode — insert rejected on sh:maxCount violation
--   6. sh:minCount — detected by validate()
--   7. sh:datatype — detected by validate() and sync mode
--
-- Uses unique IRIs (<http://shacl.test/…>) to avoid interference.
-- NOTE: setup.sql already does DROP/CREATE EXTENSION before this file.
SET search_path TO pg_ripple, public;
-- ── 1. Load a NodeShape with a PropertyShape ─────────────────────────────────
SELECT pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <http://shacl.test/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PersonShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path ex:age ;
        sh:maxCount 1 ;
    ] .
$SHACL$) AS shapes_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 shapes_loaded 
---------------
             1
(1 row)

-- ── 2. list_shapes() must show the new shape ──────────────────────────────────
SELECT count(*) AS shape_count
FROM pg_ripple.list_shapes()
WHERE shape_iri = 'http://shacl.test/PersonShape';
 shape_count 
-------------
           1
(1 row)

-- ── 3. validate() on empty graph must return conforms=true ───────────────────
SELECT (pg_ripple.validate() ->> 'conforms')::boolean AS conforms_empty;
 conforms_empty 
----------------
 t
(1 row)

-- ── 4. Insert conforming data — one Person with name and one age ──────────────
SELECT pg_ripple.insert_triple(
    '<http://shacl.test/alice>',
    '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>',
    '<http://shacl.test/Person>'
) > 0 AS type_insert_ok;
 type_insert_ok 
----------------
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<http://shacl.test/alice>',
    '<http://shacl.test/name>',
    '"Alice"^^<http://www.w3.org/2001/XMLSchema#string>'
) > 0 AS name_insert_ok;
 name_insert_ok 
----------------
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<http://shacl.test/alice>',
    '<http://shacl.test/age>',
    '"30"^^<http://www.w3.org/2001/XMLSchema#integer>'
) > 0 AS age_insert_ok;
 age_insert_ok 
---------------
 t
(1 row)

-- ── 5. validate() must detect sh:datatype violation (age is xsd:integer, not in shape) ──
-- The shape does NOT constrain datatype for age, so validate should still conform.
-- Insert a name with wrong datatype to trigger sh:datatype.
SELECT pg_ripple.insert_triple(
    '<http://shacl.test/bob>',
    '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>',
    '<http://shacl.test/Person>'
) > 0 AS bob_type_ok;
 bob_type_ok 
-------------
 t
(1 row)

-- Bob has name with wrong datatype (integer instead of xsd:string) — must violate.
SELECT pg_ripple.insert_triple(
    '<http://shacl.test/bob>',
    '<http://shacl.test/name>',
    '"99"^^<http://www.w3.org/2001/XMLSchema#integer>'
) > 0 AS bob_name_ok;
 bob_name_ok 
-------------
 t
(1 row)

-- validate() should find at least one violation for Bob's name.
SELECT jsonb_array_length(pg_ripple.validate() -> 'violations') > 0 AS has_violations;
 has_violations 
----------------
 t
(1 row)

-- ── 6. Sync mode — sh:maxCount 1 enforcement ─────────────────────────────────
SET pg_ripple.shacl_mode = 'sync';
-- First age insert is fine.
SELECT pg_ripple.insert_triple(
    '<http://shacl.test/carol>',
    '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>',
    '<http://shacl.test/Person>'
) > 0 AS carol_type_ok;
 carol_type_ok 
---------------
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<http://shacl.test/carol>',
    '<http://shacl.test/age>',
    '"25"^^<http://www.w3.org/2001/XMLSchema#integer>'
) > 0 AS carol_age1_ok;
 carol_age1_ok 
---------------
 t
(1 row)

-- Second age insert must be rejected by SHACL sync mode.
DO $$
BEGIN
    BEGIN
        PERFORM pg_ripple.insert_triple(
            '<http://shacl.test/carol>',
            '<http://shacl.test/age>',
            '"26"^^<http://www.w3.org/2001/XMLSchema#integer>'
        );
        RAISE NOTICE 'sync_rejected: false';
    EXCEPTION WHEN OTHERS THEN
        RAISE NOTICE 'sync_rejected: true';
    END;
END;
$$;
-- Reset mode.
RESET pg_ripple.shacl_mode;
-- ── 7. drop_shape() removes the shape ────────────────────────────────────────
SELECT pg_ripple.drop_shape('http://shacl.test/PersonShape') AS dropped;
 dropped 
---------
       1
(1 row)

SELECT count(*) AS shapes_after_drop
FROM pg_ripple.list_shapes()
WHERE shape_iri = 'http://shacl.test/PersonShape';
 shapes_after_drop 
-------------------
                 0
(1 row)

