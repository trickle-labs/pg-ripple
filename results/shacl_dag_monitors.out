-- shacl_dag_monitors.sql — pg_trickle multi-shape DAG validation tests (v0.8.0)
--
-- Covers:
--   1. enable_shacl_dag_monitors() returns 0 when pg_trickle is not installed
--      (graceful no-op, no error)
--   2. disable_shacl_dag_monitors() is safe to call when no monitors exist
--   3. list_shacl_dag_monitors() returns empty table when none are active
--   4. compile_shape_to_stream_sql selects correct constraints:
--      - sh:minCount compiled; sh:or skipped (complex combinator)
--   5. shacl_dag_monitors catalog tracks created monitors
--   6. The violation_summary_dag auto-clears when violations are resolved
--      (skipped when pg_trickle is absent; guarded by DO block)
--
-- Uses unique IRIs (<http://shacl.dag.test/…>) to avoid interference.
-- NOTE: setup.sql already does DROP/CREATE EXTENSION before this file.
SET search_path TO pg_ripple, public;
-- ─── 1. enable_shacl_dag_monitors without pg_trickle returns 0 ──────────────
-- pg_trickle is not installed in the standard test environment.
-- The function must return 0 and emit a WARNING (not ERROR).
SELECT pg_ripple.enable_shacl_dag_monitors() = 0 AS returns_zero_without_pg_trickle;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
WARNING:  pg_trickle is not installed; SHACL DAG monitors are unavailable. Install pg_trickle and run SELECT pg_ripple.enable_shacl_dag_monitors() to enable.
 returns_zero_without_pg_trickle 
---------------------------------
 t
(1 row)

-- ─── 2. disable_shacl_dag_monitors is safe with no monitors ─────────────────
SELECT pg_ripple.disable_shacl_dag_monitors() = 0 AS disable_safe_when_empty;
ERROR:  schema "pg_trickle" does not exist
-- ─── 3. list_shacl_dag_monitors returns empty set ───────────────────────────
SELECT count(*) AS monitor_count FROM pg_ripple.list_shacl_dag_monitors();
 monitor_count 
---------------
             0
(1 row)

-- ─── 4. shacl_dag_monitors catalog exists and is empty ──────────────────────
SELECT count(*) AS catalog_empty FROM _pg_ripple.shacl_dag_monitors;
 catalog_empty 
---------------
             0
(1 row)

-- ─── 5. Load shapes; verify compilable vs non-compilable detection ───────────
-- Load three shapes:
--   ex:PersonShape — compilable (sh:targetClass + sh:minCount + sh:datatype)
--   ex:OrgShape    — compilable (sh:targetClass + sh:maxCount + sh:class)
--   ex:AgentShape  — NOT compilable (sh:or combinator, no direct constraints)
SELECT pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <http://shacl.dag.test/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:PersonShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .

ex:OrgShape
    a sh:NodeShape ;
    sh:targetClass ex:Organization ;
    sh:property [
        sh:path ex:ceo ;
        sh:maxCount 1 ;
        sh:class ex:Person ;
    ] .

ex:AgentShape
    a sh:NodeShape ;
    sh:targetClass ex:Agent ;
    sh:or (ex:PersonShape ex:OrgShape) .
$SHACL$) AS shapes_loaded;
 shapes_loaded 
---------------
             3
(1 row)

-- Three shapes were stored.
SELECT count(*) = 3 AS three_shapes_stored
  FROM _pg_ripple.shacl_shapes
 WHERE shape_iri LIKE 'http://shacl.dag.test/%';
 three_shapes_stored 
---------------------
 t
(1 row)

-- ─── 6. enable_shacl_dag_monitors still returns 0 (no pg_trickle) ───────────
--
-- But we verify that the function correctly compiles shapes:
-- PersonShape and OrgShape are compilable; AgentShape (sh:or only) is not.
-- The return value is 0 because pg_trickle is absent, but no error is raised.
SELECT pg_ripple.enable_shacl_dag_monitors() = 0 AS still_zero_no_pgtrickle;
WARNING:  pg_trickle is not installed; SHACL DAG monitors are unavailable. Install pg_trickle and run SELECT pg_ripple.enable_shacl_dag_monitors() to enable.
 still_zero_no_pgtrickle 
-------------------------
 t
(1 row)

-- Catalog remains empty because no stream tables were created.
SELECT count(*) AS catalog_still_empty FROM _pg_ripple.shacl_dag_monitors;
 catalog_still_empty 
---------------------
                   0
(1 row)

-- ─── 7. disable / list are idempotent ───────────────────────────────────────
SELECT pg_ripple.disable_shacl_dag_monitors() = 0 AS disable_idempotent;
ERROR:  schema "pg_trickle" does not exist
SELECT count(*) AS monitors_still_empty FROM pg_ripple.list_shacl_dag_monitors();
 monitors_still_empty 
----------------------
                    0
(1 row)

-- ─── 8. Violation detection logic (offline validate confirms same violations) ─
--
-- Insert a Person without a name → should be flagged by validate().
-- The stream-table monitors would detect the same violation when pg_trickle
-- is available; validate() serves as the ground-truth here.
SELECT pg_ripple.insert_triple(
    '<http://shacl.dag.test/bob>',
    '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>',
    '<http://shacl.dag.test/Person>'
) > 0 AS inserted_bob;
 inserted_bob 
--------------
 t
(1 row)

-- Bob has no ex:name → violation expected.
SELECT (pg_ripple.validate() ->> 'conforms')::boolean = false AS violation_detected;
 violation_detected 
--------------------
 t
(1 row)

SELECT (pg_ripple.validate() -> 'results') IS NOT NULL AS has_results;
 has_results 
-------------
 f
(1 row)

-- Fix the violation — add a name for Bob.
SELECT pg_ripple.insert_triple(
    '<http://shacl.dag.test/bob>',
    '<http://shacl.dag.test/name>',
    '"Bob"'
) > 0 AS inserted_name;
 inserted_name 
---------------
 t
(1 row)

-- Now validate() must report conforms = true.
SELECT (pg_ripple.validate() ->> 'conforms')::boolean = true AS violation_resolved;
 violation_resolved 
--------------------
 t
(1 row)

-- ─── 9. shape_iri_to_table_suffix correctness (via catalog insert test) ──────
--
-- When pg_trickle IS available this would be the stream table name; here we
-- verify the suffix logic indirectly by checking no crashes occur.
-- Insert a fake entry to confirm the catalog DDL is correct.
INSERT INTO _pg_ripple.shacl_dag_monitors
    (shape_iri, stream_table_name, constraint_summary)
VALUES
    ('http://shacl.dag.test/PersonShape',
     '_pg_ripple.shacl_viol_personshape',
     'sh:minCount 1 on http://shacl.dag.test/name; sh:datatype http://www.w3.org/2001/XMLSchema#string on http://shacl.dag.test/name');
SELECT count(*) = 1 AS catalog_entry_inserted
  FROM _pg_ripple.shacl_dag_monitors
 WHERE shape_iri = 'http://shacl.dag.test/PersonShape';
 catalog_entry_inserted 
------------------------
 t
(1 row)

-- list_shacl_dag_monitors() should now return the fake entry.
SELECT shape_iri LIKE 'http://shacl.dag.test/%' AS shape_iri_ok,
       stream_table LIKE '_pg_ripple.shacl_viol_%' AS table_name_ok,
       constraints LIKE 'sh:minCount%' AS constraints_ok
  FROM pg_ripple.list_shacl_dag_monitors()
 WHERE shape_iri = 'http://shacl.dag.test/PersonShape';
 shape_iri_ok | table_name_ok | constraints_ok 
--------------+---------------+----------------
 t            | t             | t
(1 row)

-- Cleanup.
DELETE FROM _pg_ripple.shacl_dag_monitors
 WHERE shape_iri = 'http://shacl.dag.test/PersonShape';
SELECT count(*) = 0 AS catalog_cleaned
  FROM _pg_ripple.shacl_dag_monitors;
 catalog_cleaned 
-----------------
 t
(1 row)

