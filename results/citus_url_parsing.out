-- citus_url_parsing.sql
-- CITUS-URL-01 (v0.72.0): Edge-case URL parsing tests.
--
-- The primary coverage is via Rust unit tests in src/citus.rs.
-- This pg_regress file verifies that the pg_ripple extension loads without
-- errors and that Citus-related introspection functions are callable.
SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET client_min_messages = DEFAULT;
SET search_path TO pg_ripple, public;
-- Verify that citus_available() is callable (returns boolean, no panic).
SELECT pg_ripple.citus_available() AS citus_available;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 citus_available 
-----------------
 f
(1 row)

-- Verify feature_status() includes citus entry (smoke test for citus module).
SELECT COUNT(*) > 0 AS citus_in_feature_status
FROM   pg_ripple.feature_status()
WHERE  feature_name LIKE 'citus%';
 citus_in_feature_status 
-------------------------
 t
(1 row)

-- URL parsing unit tests run as part of `cargo test` via the #[cfg(test)]
-- module in src/citus.rs (CITUS-URL-01). The following documents the coverage:
--   - Normal host:       http://worker1.internal/db     → worker1.internal
--   - IPv6 literal:      http://[::1]:5432/db           → [::1]
--   - IDN hostname:      http://xn--bcher-kva.example.com/db → xn--bcher-kva.example.com
--   - Port-only, no path: http://host:5432              → host
--   - Malformed URL:     not-a-url                      → "" (empty, not a panic)
-- All cases verified by `cargo test citus::url_parsing_tests` (see src/citus.rs).
SELECT 'CITUS-URL-01 unit tests in src/citus.rs::url_parsing_tests' AS coverage;
                          coverage                          
------------------------------------------------------------
 CITUS-URL-01 unit tests in src/citus.rs::url_parsing_tests
(1 row)

