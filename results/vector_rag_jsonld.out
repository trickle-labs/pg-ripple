-- pg_regress test: RAG retrieval with JSON-LD output format (v0.28.0)
-- Tests pg_ripple.rag_retrieve(... output_format := 'jsonld') with graceful degradation.
SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET client_min_messages = DEFAULT;
SET search_path TO pg_ripple, public;
-- Load test data with type information.
SELECT pg_ripple.load_ntriples(
    '<https://pharma.example/aspirin>   <http://www.w3.org/2000/01/rdf-schema#label> "aspirin" .' || chr(10) ||
    '<https://pharma.example/aspirin>   <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://pharma.example/Drug> .' || chr(10) ||
    '<https://pharma.example/aspirin>   <https://pharma.example/treats> <https://pharma.example/Headache> .' || chr(10)
) >= 3 AS pharma_triples_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 pharma_triples_loaded 
-----------------------
 t
(1 row)

-- Register a test prefix so JSON-LD @context can be populated.
SELECT pg_ripple.register_prefix('pharma', 'https://pharma.example/') IS NULL AS prefix_registered;
 prefix_registered 
-------------------
 f
(1 row)

-- ── rag_retrieve() with jsonld output format ──────────────────────────────────
SET client_min_messages = warning;
SELECT count(*) >= 0 AS rag_jsonld_callable
FROM pg_ripple.rag_retrieve(
    'what treats headaches?',
    k := 3,
    output_format := 'jsonld'
);
WARNING:  pg_ripple.rag_retrieve: pgvector extension not installed (PT603); install pgvector and run the 0.27.0 migration to enable hybrid search
 rag_jsonld_callable 
---------------------
 t
(1 row)

-- ── JSON-LD keys present ──────────────────────────────────────────────────────
-- When rows are returned, context_json must contain @type and @context keys.
SET client_min_messages = DEFAULT;
SELECT CASE
    WHEN COUNT(*) = 0
    THEN TRUE  -- pgvector absent: graceful degradation is correct.
    ELSE BOOL_AND(
        context_json ? '@type'
        AND context_json ? '@context'
    )
END AS context_json_has_jsonld_keys
FROM pg_ripple.rag_retrieve(
    'what treats headaches?',
    k := 3,
    output_format := 'jsonld'
);
WARNING:  pg_ripple.rag_retrieve: pgvector extension not installed (PT603); install pgvector and run the 0.27.0 migration to enable hybrid search
 context_json_has_jsonld_keys 
------------------------------
 t
(1 row)

-- ── Default format ('jsonb') does not include @type ───────────────────────────
-- In default mode, context_json must NOT include @type at the top level.
SET client_min_messages = warning;
SELECT CASE
    WHEN COUNT(*) = 0
    THEN TRUE  -- No rows: expected when pgvector is absent.
    ELSE BOOL_AND(NOT (context_json ? '@type'))
END AS default_format_no_jsonld_keys
FROM pg_ripple.rag_retrieve('what treats headaches?', k := 3);
WARNING:  pg_ripple.rag_retrieve: pgvector extension not installed (PT603); install pgvector and run the 0.27.0 migration to enable hybrid search
 default_format_no_jsonld_keys 
-------------------------------
 t
