-- v0.13.0: Fuzz integration regression tests.
--
-- Verifies that the SPARQL pipeline does not panic or produce invalid SQL for
-- a selection of adversarial inputs.  These are representative cases surfaced
-- by libFuzzer during v0.13.0 fuzz testing.
--
-- Each test verifies one of:
--   (a) Graceful error handling (pgrx::error!() turns into a PostgreSQL ERROR).
--   (b) Successful execution with a safe, empty result.
SET allow_system_table_mods = on;
-- ── Empty query ───────────────────────────────────────────────────────────────
-- An empty SPARQL string should raise a parse error, not panic.
DO $$
BEGIN
  PERFORM pg_ripple.sparql('');
EXCEPTION WHEN OTHERS THEN
  RAISE NOTICE 'caught expected error for empty query: %', sqlerrm;
END;
$$;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
-- ── Malformed SPARQL ──────────────────────────────────────────────────────────
DO $$
BEGIN
  PERFORM pg_ripple.sparql('SELECT * WHERE { MALFORMED }');
EXCEPTION WHEN OTHERS THEN
  RAISE NOTICE 'caught expected error for malformed query';
END;
$$;
-- ── Deeply nested property paths ─────────────────────────────────────────────
-- Should handle without stack overflow (max_path_depth guards recursion).
SET pg_ripple.max_path_depth = 10;
DO $$
BEGIN
  PERFORM pg_ripple.sparql($$
    SELECT ?o WHERE {
      <http://example.org/A> <http://example.org/rel>* ?o .
    }
  $$);
  RAISE NOTICE 'deep path query completed';
EXCEPTION WHEN OTHERS THEN
  RAISE NOTICE 'caught error in deep path query: %', sqlerrm;
END;
$$;
ERROR:  syntax error at or near "SELECT" at character 47
-- ── SQL injection via predicate IRI ───────────────────────────────────────────
-- IRIs with SQL metacharacters must be safely encoded to i64; never interpolated.
DO $$
BEGIN
  PERFORM pg_ripple.sparql($$
    SELECT ?o WHERE {
      ?s <http://evil.example.org/'; DROP TABLE _pg_ripple.dictionary; --/iri> ?o .
    }
  $$);
  RAISE NOTICE 'injection query completed safely';
EXCEPTION WHEN OTHERS THEN
  RAISE NOTICE 'caught error in injection query: %', sqlerrm;
END;
$$;

-- Dictionary table must still exist (injection did not succeed).
SELECT EXISTS(
  SELECT 1 FROM pg_class c
  JOIN pg_namespace n ON n.oid = c.relnamespace
  WHERE n.nspname = '_pg_ripple' AND c.relname = 'dictionary'
) AS dictionary_intact;

-- ── Unicode IRI ───────────────────────────────────────────────────────────────

DO $$
BEGIN
  PERFORM pg_ripple.sparql($$
    SELECT ?o WHERE {
      ?s <http://例え.jp/述語> ?o .
    }
  $$);
  RAISE NOTICE 'unicode IRI query completed';
EXCEPTION WHEN OTHERS THEN
  RAISE NOTICE 'caught error in unicode IRI query: %', sqlerrm;
END;
$$;

-- ── Very large literal ────────────────────────────────────────────────────────

DO $$
DECLARE
  big_literal TEXT := repeat('x', 1000000);
  q TEXT;
BEGIN
  q := $q$SELECT ?s WHERE { ?s <http://example.org/big> $q$ || quote_literal(big_literal) || $q$ . }$q$;
  PERFORM pg_ripple.sparql(q);
  RAISE NOTICE 'large literal query completed';
EXCEPTION WHEN OTHERS THEN
  RAISE NOTICE 'caught error in large literal query: %', sqlerrm;
END;
$$;

-- ── Concurrent-safe: BGP reorder with no triples ─────────────────────────────

SET pg_ripple.bgp_reorder = on;

SELECT count(*) AS empty_result FROM pg_ripple.sparql($$
  SELECT ?s ?p ?o ?x WHERE {
    ?s ?p ?o .
    ?o <http://example.org/z> ?x .
    ?x <http://example.org/w> ?s .
  }
$$);

SET pg_ripple.bgp_reorder = off;

SELECT count(*) AS empty_result_no_reorder FROM pg_ripple.sparql($$
  SELECT ?s ?p ?o ?x WHERE {
    ?s ?p ?o .
    ?o <http://example.org/z> ?x .
    ?x <http://example.org/w> ?s .
  }
$$);

SET pg_ripple.bgp_reorder = on;

-- ── Plan cache with adversarial queries ──────────────────────────────────────

-- Repeated malformed queries should not fill or corrupt the cache.
DO $$
DECLARE i INT;
BEGIN
  FOR i IN 1..5 LOOP
    BEGIN
      PERFORM pg_ripple.sparql('INVALID SPARQL ' || i::text);
    EXCEPTION WHEN OTHERS THEN
      NULL; -- expected
    END;
  END LOOP;
  RAISE NOTICE 'repeated malformed queries handled';
END;
$$;

-- ── Summary ───────────────────────────────────────────────────────────────────

SELECT 'fuzz_integration tests passed' AS status;
ERROR:  syntax error at or near "SELECT" at character 47
