-- pg_regress test: Delta table indexing during semi-naive evaluation (v0.29.0)
--
-- Tests `pg_ripple.delta_index_threshold` GUC.  When the delta temp table
-- accumulates more rows than the threshold, a B-tree index is created on
-- the (s, o) join columns to speed up subsequent fixpoint iterations.
-- NOTE: setup.sql already does DROP/CREATE EXTENSION before this file.
-- This line is a no-op when run after setup, but ensures the extension is
-- available when this file is run individually (during test discovery).
CREATE EXTENSION IF NOT EXISTS pg_ripple;
-- Load library and register GUCs by calling any pg_ripple function first.
SELECT pg_ripple.triple_count() >= 0 AS library_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 library_loaded 
----------------
 t
(1 row)

SET search_path TO pg_ripple, public;
-- Pre-test baseline.
CREATE TEMP TABLE _di_test_baseline AS
    SELECT COALESCE(MAX(i), 0) AS max_i FROM _pg_ripple.vp_rare;
-- 1. GUC exists and has default value.
SHOW pg_ripple.delta_index_threshold;
 pg_ripple.delta_index_threshold 
---------------------------------
 500
(1 row)

-- 2. GUC can be set to 0 (disable delta indexing).
SET pg_ripple.delta_index_threshold = 0;
SHOW pg_ripple.delta_index_threshold;
 pg_ripple.delta_index_threshold 
---------------------------------
 0
(1 row)

-- 3. GUC can be set to a small value (index on any delta table).
SET pg_ripple.delta_index_threshold = 1;
SHOW pg_ripple.delta_index_threshold;
 pg_ripple.delta_index_threshold 
---------------------------------
 1
(1 row)

-- 4. Restore default.
SET pg_ripple.delta_index_threshold = 500;
-- 5. Insert base triples for RDFS inference test.
SELECT pg_ripple.insert_triple(
    '<https://example.org/di/A>',
    '<http://www.w3.org/2000/01/rdf-schema#subClassOf>',
    '<https://example.org/di/B>'
) > 0 AS a_sub_b;
 a_sub_b 
---------
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<https://example.org/di/B>',
    '<http://www.w3.org/2000/01/rdf-schema#subClassOf>',
    '<https://example.org/di/C>'
) > 0 AS b_sub_c;
 b_sub_c 
---------
 t
(1 row)

-- 6. Run inference with delta indexing enabled (threshold = 1 to guarantee indexing).
SET pg_ripple.delta_index_threshold = 1;
SELECT pg_ripple.load_rules_builtin('rdfs') > 0 AS rdfs_loaded;
 rdfs_loaded 
-------------
 t
(1 row)

SELECT (pg_ripple.infer_with_stats('rdfs')->>'derived')::bigint >= 0
    AS derived_nonneg;
WARNING:  semi-naive rule compile error: variable predicate in rule body not supported
 derived_nonneg 
----------------
 t
(1 row)

SELECT pg_ripple.drop_rules('rdfs') >= 0 AS rdfs_dropped_1;
 rdfs_dropped_1 
----------------
 t
(1 row)

-- Cleanup inferred triples.
DELETE FROM _pg_ripple.vp_rare
    WHERE i > (SELECT max_i FROM _di_test_baseline);
-- 7. Run inference with delta indexing disabled (threshold = 0).
SET pg_ripple.delta_index_threshold = 0;
SELECT pg_ripple.load_rules_builtin('rdfs') > 0 AS rdfs_loaded_2;
 rdfs_loaded_2 
---------------
 t
(1 row)

SELECT (pg_ripple.infer_with_stats('rdfs')->>'derived')::bigint >= 0
    AS derived_nonneg_2;
WARNING:  semi-naive rule compile error: variable predicate in rule body not supported
 derived_nonneg_2 
------------------
 t
(1 row)

SELECT pg_ripple.drop_rules('rdfs') >= 0 AS rdfs_dropped_2;
 rdfs_dropped_2 
----------------
 t
(1 row)

-- Restore default.
SET pg_ripple.delta_index_threshold = 500;
-- 8. Cleanup.
DELETE FROM _pg_ripple.vp_rare
    WHERE i > (SELECT max_i FROM _di_test_baseline);
