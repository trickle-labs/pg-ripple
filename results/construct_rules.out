    'bad_mode',
    'CONSTRUCT { ?s <https://cwb.test/p> ?o } WHERE { GRAPH <https://cwb.test/src> { ?s <https://cwb.test/p> ?o } }',
    'https://cwb.test/target',
    'weekly'
) IS NULL AS invalid_mode_rejected;
ERROR:  construct rule mode must be 'incremental' or 'full'
