-- htap_merge.sql — Test HTAP delta/main split and compact() merge
--
-- Verifies that:
--  1. Triples inserted are visible through the HTAP view (delta path)
--  2. compact() preserves visibility (delta → main promotion)
--  3. Deletes of main-resident rows are invisibilised via tombstones
--  4. Second compact() clears tombstones; surviving triple remains visible
--
-- Uses unique IRIs (<http://htap.test/…>) to avoid interference with other tests.
-- NOTE: setup.sql already does DROP/CREATE EXTENSION before this file.
SET search_path TO pg_ripple, public;
-- ── 1. Insert two triples via the same predicate ──────────────────────────────
SELECT pg_ripple.insert_triple(
    '<http://htap.test/S1>',
    '<http://htap.test/P1>',
    '<http://htap.test/O1>'
) > 0 AS insert1_ok;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 insert1_ok 
------------
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<http://htap.test/S2>',
    '<http://htap.test/P1>',
    '<http://htap.test/O2>'
) > 0 AS insert2_ok;
 insert2_ok 
------------
 t
(1 row)

-- Both triples visible through find_triples.
SELECT count(*) AS triples_before_compact
FROM pg_ripple.find_triples(NULL, '<http://htap.test/P1>', NULL);
 triples_before_compact 
------------------------
                      2
(1 row)

-- ── 2. compact() promotes delta rows into main ────────────────────────────────
SELECT pg_ripple.compact() >= 0 AS compact_ok;
 compact_ok 
------------
 t
(1 row)

-- Triples still visible after promotion.
SELECT count(*) AS triples_after_compact
FROM pg_ripple.find_triples(NULL, '<http://htap.test/P1>', NULL);
 triples_after_compact 
-----------------------
                     2
(1 row)

-- ── 3. Delete one main-resident triple ───────────────────────────────────────
SELECT pg_ripple.delete_triple(
    '<http://htap.test/S1>',
    '<http://htap.test/P1>',
    '<http://htap.test/O1>'
) = 1 AS delete_ok;
 delete_ok 
-----------
 t
(1 row)

-- Deleted triple must be invisible; one should remain.
SELECT count(*) AS triples_after_delete
FROM pg_ripple.find_triples(NULL, '<http://htap.test/P1>', NULL);
 triples_after_delete 
----------------------
                    1
(1 row)

SELECT count(*) AS deleted_triple_gone
FROM pg_ripple.find_triples('<http://htap.test/S1>', '<http://htap.test/P1>', NULL);
 deleted_triple_gone 
---------------------
                   0
(1 row)

-- ── 4. Second compact() — tombstones cleared, survivor stays ─────────────────
SELECT pg_ripple.compact() >= 0 AS compact2_ok;
 compact2_ok 
-------------
 t
(1 row)

SELECT count(*) AS triples_after_compact2
FROM pg_ripple.find_triples(NULL, '<http://htap.test/P1>', NULL);
 triples_after_compact2 
------------------------
                      1
(1 row)

