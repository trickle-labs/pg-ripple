-- pg_regress test: RAG retrieval (v0.28.0)
-- Tests pg_ripple.rag_retrieve() with graceful degradation when pgvector is absent.
SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET client_min_messages = DEFAULT;
SET search_path TO pg_ripple, public;
-- Load test data.
SELECT pg_ripple.load_ntriples(
    '<https://pharma.example/aspirin>   <http://www.w3.org/2000/01/rdf-schema#label> "aspirin" .' || chr(10) ||
    '<https://pharma.example/ibuprofen> <http://www.w3.org/2000/01/rdf-schema#label> "ibuprofen" .' || chr(10) ||
    '<https://pharma.example/aspirin>   <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://pharma.example/Drug> .' || chr(10) ||
    '<https://pharma.example/ibuprofen> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://pharma.example/Drug> .' || chr(10)
) >= 4 AS pharma_triples_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 pharma_triples_loaded 
-----------------------
 t
(1 row)

-- ── rag_retrieve() signature check ───────────────────────────────────────────
-- Must return zero rows (graceful degradation) when pgvector is absent,
-- or result rows when pgvector is present with embeddings.
SET client_min_messages = warning;
SELECT count(*) >= 0 AS rag_retrieve_callable
FROM pg_ripple.rag_retrieve('what treats headaches?', k := 5);
WARNING:  pg_ripple.rag_retrieve: pgvector extension not installed (PT603); install pgvector and run the 0.27.0 migration to enable hybrid search
 rag_retrieve_callable 
-----------------------
 t
(1 row)

-- ── Return column types ───────────────────────────────────────────────────────
-- rag_retrieve() returns (entity_iri TEXT, label TEXT, context_json JSONB, distance FLOAT8).
SET client_min_messages = DEFAULT;
SELECT * FROM (
    SELECT
        pg_typeof(entity_iri)   = 'text'::regtype   AS entity_iri_is_text,
        pg_typeof(label)        = 'text'::regtype   AS label_is_text,
        pg_typeof(context_json) = 'jsonb'::regtype  AS context_json_is_jsonb,
        pg_typeof(distance)     = 'double precision'::regtype AS distance_is_float8
    FROM pg_ripple.rag_retrieve('what treats headaches?', k := 5)
    LIMIT 1
) t
UNION ALL
SELECT TRUE, TRUE, TRUE, TRUE
WHERE NOT EXISTS (SELECT 1 FROM pg_extension WHERE extname = 'vector');
WARNING:  pg_ripple.rag_retrieve: pgvector extension not installed (PT603); install pgvector and run the 0.27.0 migration to enable hybrid search
 entity_iri_is_text | label_is_text | context_json_is_jsonb | distance_is_float8 
--------------------+---------------+-----------------------+--------------------
 t                  | t             | t                     | t
(1 row)

-- ── context_json keys ─────────────────────────────────────────────────────────
-- When rows are returned in 'jsonb' mode, context_json must contain
-- 'label', 'types', 'properties', and 'neighbors' keys.
SET client_min_messages = warning;
SELECT CASE
    WHEN COUNT(*) = 0
    THEN TRUE  -- pgvector absent: no rows, graceful degradation is correct.
    ELSE BOOL_AND(
        context_json ? 'label'
        AND context_json ? 'types'
        AND context_json ? 'properties'
        AND context_json ? 'neighbors'
    )
END AS context_json_has_required_keys
FROM pg_ripple.rag_retrieve('what treats headaches?', k := 5);
WARNING:  pg_ripple.rag_retrieve: pgvector extension not installed (PT603); install pgvector and run the 0.27.0 migration to enable hybrid search
 context_json_has_required_keys 
--------------------------------
 t
(1 row)

-- ── sparql_filter parameter ───────────────────────────────────────────────────
-- The sparql_filter parameter should not cause an ERROR when pgvector is absent.
SELECT count(*) >= 0 AS rag_with_sparql_filter
FROM pg_ripple.rag_retrieve(
    'what treats headaches?',
    sparql_filter := '?entity a <https://pharma.example/Drug>',
    k := 3
);
