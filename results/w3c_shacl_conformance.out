-- 7. sh:nodeKind
-- ══════════════════════════════════════════════════════════════════════════════
-- 7.1 Shape: subject must be IRI (sh:IRI)
SELECT pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <https://w3c.shacl.test/> .

ex:IRINodeShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:nodeKind sh:IRI .
$SHACL$) >= 1 AS iri_nodekind_shape_loaded;
 iri_nodekind_shape_loaded 
---------------------------
