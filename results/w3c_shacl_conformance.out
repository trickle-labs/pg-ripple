-- ══════════════════════════════════════════════════════════════════════════════
-- 8. sh:or logical constraint
-- ══════════════════════════════════════════════════════════════════════════════
-- 8.1 Shape: must have name OR email
SELECT pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <https://w3c.shacl.test/> .

ex:ContactShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:or (
        [ sh:property [ sh:path ex:name ; sh:minCount 1 ] ]
        [ sh:property [ sh:path ex:email ; sh:minCount 1 ] ]
    ) .
$SHACL$) >= 1 AS contact_or_shape_loaded;
 contact_or_shape_loaded 
-------------------------
 t
(1 row)

-- 8.2 Alice has both name and email — satisfies sh:or
-- 10.3 or-shape conforms
SELECT (pg_ripple.validate() ->> 'conforms')::boolean AS or_shape_conforms;
 or_shape_conforms 
