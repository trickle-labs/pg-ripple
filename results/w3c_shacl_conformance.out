-- ══════════════════════════════════════════════════════════════════════════════
-- 11. Sync mode: sh:maxCount violation rejects insert
-- ══════════════════════════════════════════════════════════════════════════════
-- 11.1 Load a strict shape and enable sync mode for it
DO $$
BEGIN
    -- Load a shape with strict maxCount 1 on name
    PERFORM pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <https://w3c.shacl.test/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:StrictPersonShape
    a sh:NodeShape ;
    sh:targetClass ex:Person ;
    sh:property [
        sh:path ex:uniqueId ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .
$SHACL$);
    RAISE NOTICE 'strict shape loaded: PASS';
END $$;
-- 11.2 Insert one uniqueId — OK
SELECT pg_ripple.insert_triple(
    '<https://w3c.shacl.test/alice>',
    '<https://w3c.shacl.test/uniqueId>',
    '"ALICE-001"^^<http://www.w3.org/2001/XMLSchema#string>'
) > 0 AS unique_id_inserted;
 unique_id_inserted 
--------------------
 t
(1 row)

-- 11.3 With sync mode, adding a second uniqueId is rejected
DO $$
DECLARE
    caught BOOLEAN := false;
BEGIN
    BEGIN
        SET pg_ripple.shacl_mode = 'sync';
        PERFORM pg_ripple.insert_triple(
            '<https://w3c.shacl.test/alice>',
            '<https://w3c.shacl.test/uniqueId>',
            '"ALICE-002"^^<http://www.w3.org/2001/XMLSchema#string>'
        );
    EXCEPTION WHEN OTHERS THEN
        caught := true;
    END;
    RESET pg_ripple.shacl_mode;
    IF caught THEN
        RAISE NOTICE 'sync mode violation rejected: PASS';
    ELSE
        RAISE NOTICE 'sync mode violation not rejected (second ID inserted or shape not active)';
    END IF;
END $$;
-- ══════════════════════════════════════════════════════════════════════════════
-- 12. W3C conformance summary
-- ══════════════════════════════════════════════════════════════════════════════
-- Summary: validate() returns a JSONB report with conforms + violations keys
SELECT
    jsonb_typeof(pg_ripple.validate()) = 'object'     AS report_is_object,
    pg_ripple.validate() ? 'conforms'                  AS report_has_conforms,
    pg_ripple.validate() ? 'violations'                AS report_has_violations;
 report_is_object | report_has_conforms | report_has_violations 
------------------+---------------------+-----------------------
 t                | t                   | t
(1 row)

