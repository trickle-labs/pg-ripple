-- pg_regress test: Temporal RDF post-merge correctness (v0.61.0 J7-3)
-- Verifies that triples are queryable before and after a merge cycle.
SET search_path TO pg_ripple, public;
-- Insert triples into the default graph (they go to delta first).
SELECT pg_ripple.load_ntriples(
    '<https://example.org/Alice> <https://schema.org/name> "Alice"^^<http://www.w3.org/2001/XMLSchema#string> .' || E'\n' ||
    '<https://example.org/Alice> <https://schema.org/age>  "30"^^<http://www.w3.org/2001/XMLSchema#integer> .'
) = 2 AS delta_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 delta_loaded 
--------------
 t
(1 row)

-- Record the current max SID before merge.
SELECT COALESCE(MAX(i), 0) >= 0 AS pre_merge_sid_ok
FROM _pg_ripple.vp_rare;
 pre_merge_sid_ok 
------------------
 t
(1 row)

-- Verify the triples are queryable before merge.
SELECT count(*) = 2 AS pre_merge_query_ok
FROM pg_ripple.sparql(
    'SELECT ?p ?o WHERE { <https://example.org/Alice> ?p ?o }'
);
 pre_merge_query_ok 
--------------------
 t
(1 row)

-- Trigger a compact cycle (combines delta into main).
SELECT pg_ripple.compact() >= 0 AS compact_completed;
 compact_completed 
-------------------
 t
(1 row)

-- Verify the triples are still queryable after compact.
SELECT count(*) = 2 AS post_compact_query_ok
FROM pg_ripple.sparql(
    'SELECT ?p ?o WHERE { <https://example.org/Alice> ?p ?o }'
);
 post_compact_query_ok 
-----------------------
 t
(1 row)

-- Cleanup.
SELECT pg_ripple.triple_count() >= 0 AS cleanup_done;
 cleanup_done 
--------------
 t
(1 row)

