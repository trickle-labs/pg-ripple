-- pg_regress test: GraphRAG CRUD — insert entities and relationships (v0.26.0)
--
-- Covers:
--   1. Inserting gr:Entity instances into a named graph using load_trig()
--   2. Inserting a gr:Relationship linking two entities
--   3. SPARQL query to retrieve entities from the named graph
--   4. find_triples() verification
--
-- Named graph: <https://graphrag.test/crud/g1>
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET search_path TO pg_ripple, public;
-- ── Setup: load entities and a relationship into a named graph ────────────────
SELECT pg_ripple.load_trig($DATA$
@prefix gr:   <https://graphrag.org/ns/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<https://graphrag.test/crud/g1> {
    <https://graphrag.test/crud/entity/alice>
        rdf:type            gr:Entity ;
        gr:title            "Alice" ;
        gr:type             "PERSON" ;
        gr:description      "A test person entity" ;
        gr:frequency        "3"^^xsd:integer ;
        gr:degree           "2"^^xsd:integer .

    <https://graphrag.test/crud/entity/bob>
        rdf:type            gr:Entity ;
        gr:title            "Bob" ;
        gr:type             "PERSON" .

    <https://graphrag.test/crud/rel/1>
        rdf:type            gr:Relationship ;
        gr:source           <https://graphrag.test/crud/entity/alice> ;
        gr:target           <https://graphrag.test/crud/entity/bob> ;
        gr:weight           "0.8"^^xsd:float .
}
$DATA$) > 0 AS data_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 data_loaded 
-------------
 t
(1 row)

-- ── Verify entity count via find_triples_in_graph ────────────────────────────
SELECT count(*) = 2 AS two_entities_present
FROM pg_ripple.find_triples_in_graph(
    NULL,
    '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>',
    '<https://graphrag.org/ns/Entity>',
    'https://graphrag.test/crud/g1'
);
 two_entities_present 
----------------------
 t
(1 row)

-- ── Verify relationship count ─────────────────────────────────────────────────
SELECT count(*) = 1 AS one_relationship_present
FROM pg_ripple.find_triples_in_graph(
    NULL,
    '<http://www.w3.org/1999/02/22-rdf-syntax-ns#type>',
    '<https://graphrag.org/ns/Relationship>',
    'https://graphrag.test/crud/g1'
);
 one_relationship_present 
--------------------------
 t
(1 row)

-- ── SPARQL: query entities in named graph ─────────────────────────────────────
SELECT count(*) = 2 AS sparql_finds_two_entities
FROM pg_ripple.sparql(
    'SELECT ?entity WHERE { GRAPH <https://graphrag.test/crud/g1> { ?entity <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://graphrag.org/ns/Entity> } }'
);
 sparql_finds_two_entities 
---------------------------
 t
(1 row)

-- ── SPARQL: query relationship source and target ──────────────────────────────
SELECT count(*) = 1 AS sparql_finds_relationship_source
FROM pg_ripple.sparql(
    'SELECT ?rel WHERE { GRAPH <https://graphrag.test/crud/g1> { ?rel <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <https://graphrag.org/ns/Relationship> ; <https://graphrag.org/ns/source> <https://graphrag.test/crud/entity/alice> } }'
);
 sparql_finds_relationship_source 
----------------------------------
 t
(1 row)

-- ── Verify Alice title triple ─────────────────────────────────────────────────
SELECT count(*) >= 1 AS alice_has_title
FROM pg_ripple.find_triples_in_graph(
    '<https://graphrag.test/crud/entity/alice>',
    '<https://graphrag.org/ns/title>',
    NULL,
    'https://graphrag.test/crud/g1'
);
 alice_has_title 
-----------------
 t
(1 row)

-- ── Cleanup: remove graphrag.test triples ────────────────────────────────────
DO $$
BEGIN
    DELETE FROM _pg_ripple.vp_rare
    WHERE s IN (SELECT id FROM _pg_ripple.dictionary WHERE value LIKE 'https://graphrag.test/%')
       OR p IN (SELECT id FROM _pg_ripple.dictionary WHERE value LIKE 'https://graphrag.test/%')
       OR s IN (SELECT id FROM _pg_ripple.dictionary WHERE value LIKE 'https://graphrag.org/ns/%')
       OR p IN (SELECT id FROM _pg_ripple.dictionary WHERE value LIKE 'https://graphrag.org/ns/%');
END $$;
