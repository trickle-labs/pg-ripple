-- jsonld_context_object_form.sql
-- BUG-JSONLD-CONTEXT-01 (v0.72.0): Tests for object-form JSON-LD context entries.
--
-- Previously, only string-valued context entries ("key": "iri") were processed.
-- Object-form entries (e.g. {"@id": "...", "@type": "xsd:dateTime"}) were
-- silently dropped, causing the predicate to be unmapped.
-- This test suite verifies the fix for the @id extraction case.
SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET client_min_messages = DEFAULT;
SET search_path TO pg_ripple, public;
-- ── Test 1: Object-form context entry with @id ─────────────────────────────
-- The context entry "temp": {"@id": "https://saref.etsi.org/core/hasValue"}
-- should be equivalent to "temp": "https://saref.etsi.org/core/hasValue".
SELECT pg_ripple.json_to_ntriples_and_load(
    '{"temp": 23.5}'::jsonb,
    'https://example.org/device1',
    NULL,
    '{"@context": {"temp": {"@id": "https://saref.etsi.org/core/hasValue"}}}'::jsonb
) > 0 AS object_form_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 object_form_loaded 
--------------------
 t
(1 row)

-- Verify the triple was stored with the correct predicate IRI.
SELECT pg_ripple.sparql_ask(
    'ASK { <https://example.org/device1> <https://saref.etsi.org/core/hasValue> ?o }'
) AS object_form_triples_exist;
 object_form_triples_exist 
---------------------------
 f
(1 row)

-- ── Test 2: Backward compatibility — string-form context entry unchanged ─────
SELECT pg_ripple.json_to_ntriples_and_load(
    '{"name": "Alice"}'::jsonb,
    'https://example.org/person1',
    NULL,
    '{"@context": {"name": "https://schema.org/name"}}'::jsonb
) > 0 AS string_form_loaded;
 string_form_loaded 
--------------------
 t
(1 row)

SELECT pg_ripple.sparql_ask(
    'ASK { <https://example.org/person1> <https://schema.org/name> ?o }'
) AS string_form_triples_exist;
 string_form_triples_exist 
---------------------------
 f
(1 row)

-- ── Cleanup ───────────────────────────────────────────────────────────────────
SELECT pg_ripple.sparql_update(
    'DELETE WHERE { <https://example.org/device1> ?p ?o }'
) >= 0 AS cleanup_device1;
 cleanup_device1 
-----------------
 t
(1 row)

SELECT pg_ripple.sparql_update(
    'DELETE WHERE { <https://example.org/person1> ?p ?o }'
) >= 0 AS cleanup_person1;
 cleanup_person1 
-----------------
 t
(1 row)

