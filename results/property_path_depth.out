-- pg_regress test: max_path_depth GUC (v0.24.0)
--
-- Tests that the pg_ripple.max_path_depth GUC is registered,
-- accessible, and has the correct default.
SET search_path TO pg_ripple, public;
-- Load library so _PG_init registers GUCs (required when shared_preload_libraries is not set).
LOAD '$libdir/pg_ripple';
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
-- Pre-test cleanup: remove any pp/* triples from all storage.
DO $$
DECLARE
    pp_ids BIGINT[];
    pred_id BIGINT;
BEGIN
    SELECT array_agg(id) INTO pp_ids
    FROM _pg_ripple.dictionary WHERE value LIKE 'https://example.org/pp/%';
    IF pp_ids IS NULL THEN RETURN; END IF;
    DELETE FROM _pg_ripple.vp_rare WHERE s = ANY(pp_ids) OR o = ANY(pp_ids);
    FOR pred_id IN SELECT id FROM _pg_ripple.predicates WHERE table_oid IS NOT NULL LOOP
        BEGIN
            EXECUTE format('DELETE FROM _pg_ripple.vp_%s_delta WHERE s = ANY($1) OR o = ANY($1)', pred_id) USING pp_ids;
            EXECUTE format('DELETE FROM _pg_ripple.vp_%s_main  WHERE s = ANY($1) OR o = ANY($1)', pred_id) USING pp_ids;
        EXCEPTION WHEN undefined_table THEN NULL;
        END;
    END LOOP;
END $$;
-- ── 1. GUC exists and has correct default value ───────────────────────────────
SELECT current_setting('pg_ripple.max_path_depth')::int = 100 AS default_is_100;
 default_is_100 
----------------
 t
(1 row)

-- ── 2. GUC can be changed ────────────────────────────────────────────────────
SET pg_ripple.max_path_depth = 10;
SELECT current_setting('pg_ripple.max_path_depth')::int = 10 AS set_to_10;
 set_to_10 
-----------
 t
(1 row)

-- ── 3. Restore default ───────────────────────────────────────────────────────
RESET pg_ripple.max_path_depth;
SELECT current_setting('pg_ripple.max_path_depth')::int = 100 AS back_to_100;
 back_to_100 
-------------
 t
(1 row)

-- ── 4. GUC affects SPARQL property path queries ───────────────────────────────
-- Insert a 5-hop chain: a → b → c → d → e → f
SELECT pg_ripple.insert_triple('<https://example.org/pp/a>', '<https://example.org/pp/hop>', '<https://example.org/pp/b>') > 0 AS hop1;
 hop1 
------
 t
(1 row)

SELECT pg_ripple.insert_triple('<https://example.org/pp/b>', '<https://example.org/pp/hop>', '<https://example.org/pp/c>') > 0 AS hop2;
 hop2 
------
 t
(1 row)

SELECT pg_ripple.insert_triple('<https://example.org/pp/c>', '<https://example.org/pp/hop>', '<https://example.org/pp/d>') > 0 AS hop3;
 hop3 
------
 t
(1 row)

SELECT pg_ripple.insert_triple('<https://example.org/pp/d>', '<https://example.org/pp/hop>', '<https://example.org/pp/e>') > 0 AS hop4;
 hop4 
------
 t
(1 row)

SELECT pg_ripple.insert_triple('<https://example.org/pp/e>', '<https://example.org/pp/hop>', '<https://example.org/pp/f>') > 0 AS hop5;
 hop5 
------
 t
(1 row)

-- With default depth=100, a+ path should reach all nodes.
SET pg_ripple.max_path_depth = 100;
SELECT count(*) >= 1 AS transitive_reachable
FROM pg_ripple.sparql(
    'PREFIX pp: <https://example.org/pp/> '
    'SELECT ?x WHERE { pp:a <https://example.org/pp/hop>+ ?x }'
);
 transitive_reachable 
----------------------
 t
(1 row)

-- Restore.
RESET pg_ripple.max_path_depth;
SELECT current_setting('pg_ripple.max_path_depth')::int = 100 AS restored_ok;
 restored_ok 
-------------
 t
(1 row)

-- Post-test cleanup: remove all pp/* triples so later tests are not polluted.
DO $$
DECLARE
    pp_ids BIGINT[];
    pred_id BIGINT;
BEGIN
    SELECT array_agg(id) INTO pp_ids
    FROM _pg_ripple.dictionary WHERE value LIKE 'https://example.org/pp/%';
    IF pp_ids IS NULL THEN RETURN; END IF;
    DELETE FROM _pg_ripple.vp_rare WHERE s = ANY(pp_ids) OR o = ANY(pp_ids) OR p = ANY(pp_ids);
    FOR pred_id IN SELECT id FROM _pg_ripple.predicates WHERE table_oid IS NOT NULL LOOP
        BEGIN
            EXECUTE format('DELETE FROM _pg_ripple.vp_%s_delta WHERE s=ANY($1) OR o=ANY($1)', pred_id) USING pp_ids;
            EXECUTE format('DELETE FROM _pg_ripple.vp_%s_main  WHERE s=ANY($1) OR o=ANY($1)', pred_id) USING pp_ids;
        EXCEPTION WHEN undefined_table THEN NULL;
        END;
    END LOOP;
END $$;
