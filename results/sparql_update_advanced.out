-- pg_regress test: SPARQL Update Advanced — ADD, COPY, MOVE (v0.38.0)
-- Namespace: https://advcopy.test/
--
-- spargebra 0.4 desugars ADD/COPY/MOVE into Drop+DeleteInsert sequences,
-- so they are handled transparently by the existing delete_insert engine.
DO $$
BEGIN
    DELETE FROM _pg_ripple.vp_rare
    WHERE p IN (
        SELECT id FROM _pg_ripple.dictionary
        WHERE value LIKE 'https://advcopy.test/%'
    );
END $$;
-- ── Setup: insert triples into two source graphs ──────────────────────────────
SELECT pg_ripple.sparql_update(
    'INSERT DATA {
       GRAPH <https://advcopy.test/src> {
         <https://advcopy.test/s1> <https://advcopy.test/p> <https://advcopy.test/o1> .
         <https://advcopy.test/s2> <https://advcopy.test/p> <https://advcopy.test/o2>
       }
     }'
) = 2 AS two_in_src;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 two_in_src 
------------
 t
(1 row)

SELECT pg_ripple.sparql_update(
    'INSERT DATA {
       GRAPH <https://advcopy.test/dst> {
         <https://advcopy.test/s3> <https://advcopy.test/p> <https://advcopy.test/o3>
       }
     }'
) = 1 AS one_in_dst;
 one_in_dst 
------------
 t
(1 row)

-- ── ADD: copy src → dst (destination retains its existing triples) ────────────
SELECT pg_ripple.sparql_update(
    'ADD <https://advcopy.test/src> TO <https://advcopy.test/dst>'
) >= 0 AS add_ok;
 add_ok 
--------
 t
(1 row)

-- dst now has both its original triple and the two from src (3 total).
SELECT count(*) = 3 AS dst_has_three
FROM pg_ripple.sparql(
    'SELECT ?s WHERE { GRAPH <https://advcopy.test/dst> { ?s <https://advcopy.test/p> ?o } }'
);
 dst_has_three 
---------------
 t
(1 row)

-- src is unchanged (ADD does not remove the source).
SELECT count(*) = 2 AS src_unchanged
FROM pg_ripple.sparql(
    'SELECT ?s WHERE { GRAPH <https://advcopy.test/src> { ?s <https://advcopy.test/p> ?o } }'
);
 src_unchanged 
---------------
 t
(1 row)

-- ── Reset dst for COPY test ───────────────────────────────────────────────────
SELECT pg_ripple.sparql_update(
    'CLEAR GRAPH <https://advcopy.test/dst>'
) >= 0 AS dst_cleared;
 dst_cleared 
-------------
 t
(1 row)

SELECT pg_ripple.sparql_update(
    'INSERT DATA {
       GRAPH <https://advcopy.test/dst> {
         <https://advcopy.test/s3> <https://advcopy.test/p> <https://advcopy.test/o3>
       }
     }'
) = 1 AS one_in_dst_again;
 one_in_dst_again 
------------------
 t
(1 row)

-- ── COPY: replace dst with src contents (drops dst first) ────────────────────
SELECT pg_ripple.sparql_update(
    'COPY <https://advcopy.test/src> TO <https://advcopy.test/dst>'
) >= 0 AS copy_ok;
 copy_ok 
---------
 t
(1 row)

-- dst now contains exactly what src had (2 triples), old dst triple is gone.
SELECT count(*) = 2 AS dst_has_two_from_src
FROM pg_ripple.sparql(
    'SELECT ?s WHERE { GRAPH <https://advcopy.test/dst> { ?s <https://advcopy.test/p> ?o } }'
);
 dst_has_two_from_src 
----------------------
 t
(1 row)

-- src is unchanged after COPY.
SELECT count(*) = 2 AS src_still_two
FROM pg_ripple.sparql(
    'SELECT ?s WHERE { GRAPH <https://advcopy.test/src> { ?s <https://advcopy.test/p> ?o } }'
);
 src_still_two 
---------------
 t
(1 row)

-- ── MOVE: move src → dst2 (src is emptied, dst2 gets src's triples) ──────────
SELECT pg_ripple.sparql_update(
    'MOVE <https://advcopy.test/src> TO <https://advcopy.test/dst2>'
) >= 0 AS move_ok;
 move_ok 
---------
 t
(1 row)

-- dst2 now has the two triples from src.
SELECT count(*) = 2 AS dst2_has_two
FROM pg_ripple.sparql(
    'SELECT ?s WHERE { GRAPH <https://advcopy.test/dst2> { ?s <https://advcopy.test/p> ?o } }'
);
 dst2_has_two 
--------------
 t
(1 row)

-- src is empty after MOVE.
SELECT count(*) = 0 AS src_empty_after_move
FROM pg_ripple.sparql(
    'SELECT ?s WHERE { GRAPH <https://advcopy.test/src> { ?s <https://advcopy.test/p> ?o } }'
);
 src_empty_after_move 
----------------------
 t
(1 row)

-- ── Identity cases (ADD/COPY/MOVE graph TO same graph are no-ops) ─────────────
SELECT pg_ripple.sparql_update(
    'ADD <https://advcopy.test/dst> TO <https://advcopy.test/dst>'
) = 0 AS add_identity_ok;
 add_identity_ok 
-----------------
