(1 row)

-- ── Cleanup ───────────────────────────────────────────────────────────────────
DO $$
DECLARE
    adv_ids BIGINT[];
    pred_id BIGINT;
BEGIN
    SELECT array_agg(id) INTO adv_ids
    FROM _pg_ripple.dictionary WHERE value LIKE 'https://advcopy.test/%';
    IF adv_ids IS NULL THEN RETURN; END IF;
    DELETE FROM _pg_ripple.vp_rare
    WHERE s = ANY(adv_ids) OR o = ANY(adv_ids) OR p = ANY(adv_ids);
    FOR pred_id IN
        SELECT id FROM _pg_ripple.predicates WHERE table_oid IS NOT NULL
    LOOP
        BEGIN
            EXECUTE format(
                'DELETE FROM _pg_ripple.vp_%s_delta WHERE s=ANY($1) OR o=ANY($1)',
                pred_id) USING adv_ids;
            EXECUTE format(
                'DELETE FROM _pg_ripple.vp_%s_main  WHERE s=ANY($1) OR o=ANY($1)',
                pred_id) USING adv_ids;
        EXCEPTION WHEN undefined_table THEN NULL;
        END;
    END LOOP;
END $$;
