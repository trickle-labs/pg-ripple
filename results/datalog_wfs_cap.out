-- pg_regress test: WFS iteration-cap behaviour (v0.45.0)
--
-- Verifies that when a mutually-recursive negation cycle reaches
-- pg_ripple.wfs_max_iterations, the engine:
--   (a) returns without error (no crash)
--   (b) result JSONB has 'stratifiable' = false
--   (c) a PostgreSQL WARNING with code PT520 would be emitted
--   (d) both 'certain' and 'unknown' counts are >= 0 (partial result returned)
--   (e) 'derived' = 'certain' + 'unknown' (accounting identity holds)
-- Suppress internal IF-NOT-EXISTS NOTICEs from load_rules / infer_wfs.
SET client_min_messages = WARNING;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SELECT pg_ripple.triple_count() >= 0 AS library_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 library_loaded 
----------------
 t
(1 row)

SET search_path TO pg_ripple, public;
-- ── Part 1: GUC wfs_max_iterations is settable ────────────────────────────────
-- Default is 100; lower it so the cap test is cheap.
SHOW pg_ripple.wfs_max_iterations;
 pg_ripple.wfs_max_iterations 
------------------------------
 100
(1 row)

SET pg_ripple.wfs_max_iterations = 3;
SHOW pg_ripple.wfs_max_iterations;
 pg_ripple.wfs_max_iterations 
------------------------------
 3
(1 row)

-- ── Part 2: Mutually-recursive negation hitting the iteration cap ─────────────
-- Load a mutually-recursive negation programme: trusted/untrusted for a person.
-- With wfs_max_iterations = 3 and a deeply cyclic programme, the alternating
-- fixpoint will not converge.
-- Base data: multiple persons to ensure multiple derived attempts.
SELECT pg_ripple.insert_triple(
    '<https://ex.org/wfs_cap/p1>', '<https://ex.org/wfs_cap/person>', '<https://ex.org/wfs_cap/yes>'
) > 0 AS p1;
 p1 
----
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<https://ex.org/wfs_cap/p2>', '<https://ex.org/wfs_cap/person>', '<https://ex.org/wfs_cap/yes>'
) > 0 AS p2;
 p2 
----
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<https://ex.org/wfs_cap/p3>', '<https://ex.org/wfs_cap/person>', '<https://ex.org/wfs_cap/yes>'
) > 0 AS p3;
 p3 
----
 t
(1 row)

-- Load mutual negation rule set.
SELECT pg_ripple.load_rules(
    '?x <https://ex.org/wfs_cap/trusted>   <https://ex.org/wfs_cap/yes> :- '
        '?x <https://ex.org/wfs_cap/person>    <https://ex.org/wfs_cap/yes>, '
        'NOT ?x <https://ex.org/wfs_cap/untrusted> <https://ex.org/wfs_cap/yes> . '
    '?x <https://ex.org/wfs_cap/untrusted> <https://ex.org/wfs_cap/yes> :- '
        '?x <https://ex.org/wfs_cap/person>    <https://ex.org/wfs_cap/yes>, '
        'NOT ?x <https://ex.org/wfs_cap/trusted>   <https://ex.org/wfs_cap/yes> .',
    'wfs_cap_test'
) > 0 AS rules_loaded;
 rules_loaded 
--------------
 t
(1 row)

-- ── Part 3: Run infer_wfs() and verify the cap behaviour ─────────────────────
-- (a) infer_wfs() returns without error (no crash); result is a JSONB object.
SELECT jsonb_typeof(pg_ripple.infer_wfs('wfs_cap_test')) = 'object'
    AS infer_wfs_returns_object;
 infer_wfs_returns_object 
--------------------------
 t
(1 row)

-- (b) stratifiable = false (the programme has cyclic negation).
SELECT (pg_ripple.infer_wfs('wfs_cap_test') ->> 'stratifiable')::boolean = false
    AS stratifiable_is_false;
 stratifiable_is_false 
-----------------------
 t
(1 row)

-- (c) both certain and unknown counts are valid non-negative integers.
SELECT (pg_ripple.infer_wfs('wfs_cap_test') ->> 'certain')::int >= 0
    AS certain_count_nonneg;
 certain_count_nonneg 
----------------------
 t
(1 row)

SELECT (pg_ripple.infer_wfs('wfs_cap_test') ->> 'unknown')::int >= 0
    AS unknown_count_nonneg;
 unknown_count_nonneg 
----------------------
 t
(1 row)

-- (d) derived = certain + unknown (accounting identity).
SELECT
    (pg_ripple.infer_wfs('wfs_cap_test') ->> 'derived')::int =
    (pg_ripple.infer_wfs('wfs_cap_test') ->> 'certain')::int +
    (pg_ripple.infer_wfs('wfs_cap_test') ->> 'unknown')::int
    AS derived_eq_certain_plus_unknown;
 derived_eq_certain_plus_unknown 
---------------------------------
 t
(1 row)

-- (e) has required JSONB keys.
SELECT pg_ripple.infer_wfs('wfs_cap_test') ? 'iterations' AS has_iterations;
 has_iterations 
----------------
 t
(1 row)

SELECT pg_ripple.infer_wfs('wfs_cap_test') ? 'derived'    AS has_derived;
 has_derived 
-------------
 t
(1 row)

SELECT pg_ripple.infer_wfs('wfs_cap_test') ? 'certain'    AS has_certain;
 has_certain 
-------------
 t
(1 row)

SELECT pg_ripple.infer_wfs('wfs_cap_test') ? 'unknown'    AS has_unknown;
 has_unknown 
-------------
 t
(1 row)

-- ── Cleanup ────────────────────────────────────────────────────────────────────
SELECT pg_ripple.drop_rules('wfs_cap_test') >= 0 AS rules_dropped;
 rules_dropped 
---------------
 t
(1 row)

SELECT pg_ripple.delete_triple(
    '<https://ex.org/wfs_cap/p1>', '<https://ex.org/wfs_cap/person>', '<https://ex.org/wfs_cap/yes>'
) >= 0 AS del_p1;
 del_p1 
--------
 t
(1 row)

SELECT pg_ripple.delete_triple(
    '<https://ex.org/wfs_cap/p2>', '<https://ex.org/wfs_cap/person>', '<https://ex.org/wfs_cap/yes>'
) >= 0 AS del_p2;
 del_p2 
--------
 t
(1 row)

SELECT pg_ripple.delete_triple(
    '<https://ex.org/wfs_cap/p3>', '<https://ex.org/wfs_cap/person>', '<https://ex.org/wfs_cap/yes>'
) >= 0 AS del_p3;
 del_p3 
--------
 t
(1 row)

-- Restore default.
RESET pg_ripple.wfs_max_iterations;
