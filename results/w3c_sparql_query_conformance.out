-- ══════════════════════════════════════════════════════════════════════════════
-- 7. Negation: NOT EXISTS and MINUS
-- ══════════════════════════════════════════════════════════════════════════════
-- 7.1 NOT EXISTS: persons with NO email
SELECT count(*) = 2 AS neg_not_exists
FROM pg_ripple.sparql($$
    SELECT ?s WHERE {
        ?s <https://w3c.sparql.query.test/type> <https://w3c.sparql.query.test/Person> .
        FILTER NOT EXISTS { ?s <https://w3c.sparql.query.test/email> ?e . }
    }
$$);
 neg_not_exists 
----------------
 t
(1 row)

-- 7.2 MINUS: same as NOT EXISTS semantics
SELECT count(*) = 2 AS neg_minus
FROM pg_ripple.sparql($$
    SELECT ?s WHERE {
        ?s <https://w3c.sparql.query.test/type> <https://w3c.sparql.query.test/Person> .
        MINUS { ?s <https://w3c.sparql.query.test/email> ?e . }
    }
$$);
 neg_minus 
-----------
 t
(1 row)

