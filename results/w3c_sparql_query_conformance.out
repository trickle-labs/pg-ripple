-- ══════════════════════════════════════════════════════════════════════════════
-- 10. ASK and CONSTRUCT
-- ══════════════════════════════════════════════════════════════════════════════
-- 10.1 ASK: does alice know bob?
SELECT pg_ripple.sparql_ask($$
    ASK { <https://w3c.sparql.query.test/alice>
              <https://w3c.sparql.query.test/knows>
              <https://w3c.sparql.query.test/bob> . }
$$) AS ask_alice_knows_bob;
 ask_alice_knows_bob 
---------------------
 t
(1 row)

-- 10.2 ASK: does alice know dave? (no)
SELECT pg_ripple.sparql_ask($$
    ASK { <https://w3c.sparql.query.test/alice>
              <https://w3c.sparql.query.test/knows>
              <https://w3c.sparql.query.test/dave> . }
$$) AS ask_alice_knows_dave;
 ask_alice_knows_dave 
----------------------
 f
(1 row)

-- 10.3 CONSTRUCT: build knows graph
SELECT count(*) >= 3 AS construct_knows_graph
FROM pg_ripple.sparql_construct($$
    CONSTRUCT { ?s <https://w3c.sparql.query.test/connected_to> ?o . }
    WHERE {
        ?s <https://w3c.sparql.query.test/knows> ?o .
    }
$$);
 construct_knows_graph 
-----------------------
