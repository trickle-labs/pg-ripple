-- ══════════════════════════════════════════════════════════════════════════════
-- 9. Language-tagged Literals
-- ══════════════════════════════════════════════════════════════════════════════
-- 9.1 Store and retrieve language-tagged literal
SELECT count(*) = 1 AS lang_tagged_stored
FROM pg_ripple.find_triples(
    '<https://w3c.sparql.query.test/alice>',
    '<https://w3c.sparql.query.test/lang>',
    NULL
);
 lang_tagged_stored 
--------------------
 t
(1 row)

-- 9.2 LANG() function returns language tag
SELECT count(*) = 1 AS fn_lang
FROM pg_ripple.sparql($$
    SELECT (LANG(?l) AS ?tag) WHERE {
        <https://w3c.sparql.query.test/alice>
            <https://w3c.sparql.query.test/lang> ?l .
    }
$$);
 fn_lang 
---------
 t
(1 row)

-- 9.3 FILTER by lang tag equality
SELECT count(*) = 1 AS lang_filter
FROM pg_ripple.sparql($$
    SELECT ?l WHERE {
        ?s <https://w3c.sparql.query.test/lang> ?l .
        FILTER (LANG(?l) = "fr")
    }
$$);
