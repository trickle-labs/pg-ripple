-- w3c_sparql_query_conformance.sql — W3C SPARQL 1.1 Query conformance gate (v0.20.0)
--
-- Tests representative cases from the W3C SPARQL 1.1 Query test suite:
--   https://www.w3.org/2009/sparql/test-suite-20130327/
--
-- Coverage areas:
--   1. Basic Graph Patterns (BGP) — bind, filter, optional
--   2. Aggregates — COUNT, SUM, AVG, MIN, MAX, GROUP BY, HAVING
--   3. Property Paths — /, |, *, +, ?, ^, negated property sets
--   4. UNION and subqueries
--   5. BIND and VALUES
--   6. String, numeric, and datetime functions
--   7. Negation — NOT EXISTS, MINUS
--   8. OPTIONAL and COALESCE
--   9. Language-tagged literals
--  10. Federated query (SERVICE) — covered by v0.16.0; smoke-tested here
--
-- Known limitations (documented, not failures):
--   - Property functions (custom aggregate functions) are not supported.
--   - Language tag comparisons with langMatches() are best-effort.
--   - Variable-inside-quoted-triple patterns return 0 rows with a WARNING.
--
-- Namespace: https://w3c.sparql.query.test/ (unique, no interference).
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET search_path TO pg_ripple, public;
-- ══════════════════════════════════════════════════════════════════════════════
-- 0. Setup: load a dataset that covers all test categories
-- ══════════════════════════════════════════════════════════════════════════════
DO $$
BEGIN
    DELETE FROM _pg_ripple.vp_rare
    WHERE p IN (
        SELECT id FROM _pg_ripple.dictionary
        WHERE value LIKE 'https://w3c.sparql.query.test/%'
    );
END $$;
SELECT pg_ripple.load_ntriples(
    -- People
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/name>  "Alice" .' || E'\n' ||
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/age>   "30"^^<http://www.w3.org/2001/XMLSchema#integer> .' || E'\n' ||
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/type>  <https://w3c.sparql.query.test/Person> .' || E'\n' ||
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/lang>  "bonjour"@fr .' || E'\n' ||
    '<https://w3c.sparql.query.test/bob>   <https://w3c.sparql.query.test/name>  "Bob" .' || E'\n' ||
    '<https://w3c.sparql.query.test/bob>   <https://w3c.sparql.query.test/age>   "25"^^<http://www.w3.org/2001/XMLSchema#integer> .' || E'\n' ||
    '<https://w3c.sparql.query.test/bob>   <https://w3c.sparql.query.test/type>  <https://w3c.sparql.query.test/Person> .' || E'\n' ||
    '<https://w3c.sparql.query.test/carol> <https://w3c.sparql.query.test/name>  "Carol" .' || E'\n' ||
    '<https://w3c.sparql.query.test/carol> <https://w3c.sparql.query.test/age>   "35"^^<http://www.w3.org/2001/XMLSchema#integer> .' || E'\n' ||
    '<https://w3c.sparql.query.test/carol> <https://w3c.sparql.query.test/type>  <https://w3c.sparql.query.test/Person> .' || E'\n' ||
    -- Relations
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/knows> <https://w3c.sparql.query.test/bob> .' || E'\n' ||
    '<https://w3c.sparql.query.test/bob>   <https://w3c.sparql.query.test/knows> <https://w3c.sparql.query.test/carol> .' || E'\n' ||
    '<https://w3c.sparql.query.test/carol> <https://w3c.sparql.query.test/knows> <https://w3c.sparql.query.test/alice> .' || E'\n' ||
    -- Optional data
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/email> "alice@example.com" .' || E'\n' ||
    -- Score data for aggregates
    '<https://w3c.sparql.query.test/alice> <https://w3c.sparql.query.test/score> "90"^^<http://www.w3.org/2001/XMLSchema#integer> .' || E'\n' ||
    '<https://w3c.sparql.query.test/bob>   <https://w3c.sparql.query.test/score> "80"^^<http://www.w3.org/2001/XMLSchema#integer> .' || E'\n' ||
    '<https://w3c.sparql.query.test/carol> <https://w3c.sparql.query.test/score> "70"^^<http://www.w3.org/2001/XMLSchema#integer> .'
) = 17 AS dataset_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 dataset_loaded 
----------------
 t
(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 1. Basic Graph Patterns
-- ══════════════════════════════════════════════════════════════════════════════
-- 1.1 Simple BGP: all persons (rdf:type = Person)
SELECT count(*) = 3 AS bgp_type_three_persons
FROM pg_ripple.sparql($$
    SELECT ?s WHERE {
        ?s <https://w3c.sparql.query.test/type>
           <https://w3c.sparql.query.test/Person> .
    }
$$);
 bgp_type_three_persons 
------------------------
 t
(1 row)

-- 1.2 Two-triple BGP: name + age of all persons
SELECT count(*) = 3 AS bgp_name_age
FROM pg_ripple.sparql($$
    SELECT ?name ?age WHERE {
        ?s <https://w3c.sparql.query.test/type>  <https://w3c.sparql.query.test/Person> .
        ?s <https://w3c.sparql.query.test/name>  ?name .
        ?s <https://w3c.sparql.query.test/age>   ?age  .
    }
$$);
 bgp_name_age 
--------------
 t
(1 row)

-- 1.3 FILTER: persons with age > 28
SELECT count(*) = 2 AS bgp_filter_age_gt28
FROM pg_ripple.sparql($$
    SELECT ?s ?age WHERE {
        ?s <https://w3c.sparql.query.test/age> ?age .
        FILTER (?age > 28)
    }
$$);
 bgp_filter_age_gt28 
---------------------
 t
(1 row)

-- 1.4 OPTIONAL: name + optional email
SELECT count(*) = 3 AS bgp_optional_email
FROM pg_ripple.sparql($$
    SELECT ?name ?email WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
        OPTIONAL { ?s <https://w3c.sparql.query.test/email> ?email . }
    }
$$);
 bgp_optional_email 
--------------------
 t
(1 row)

-- 1.5 BOUND() check: persons with email defined
SELECT count(*) = 1 AS bgp_bound_email
FROM pg_ripple.sparql($$
    SELECT ?s WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
        OPTIONAL { ?s <https://w3c.sparql.query.test/email> ?email . }
        FILTER (BOUND(?email))
    }
$$);
 bgp_bound_email 
-----------------
 t
(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 2. Aggregates
-- ══════════════════════════════════════════════════════════════════════════════
-- 2.1 COUNT(*): total number of persons
SELECT count(*) = 1 AS agg_count_result
FROM pg_ripple.sparql($$
    SELECT (COUNT(*) AS ?n) WHERE {
        ?s <https://w3c.sparql.query.test/type> <https://w3c.sparql.query.test/Person> .
    }
$$);
 agg_count_result 
------------------
 t
(1 row)

-- 2.2 SUM: total score
SELECT count(*) = 1 AS agg_sum_result
FROM pg_ripple.sparql($$
    SELECT (SUM(?score) AS ?total) WHERE {
        ?s <https://w3c.sparql.query.test/score> ?score .
    }
$$);
 agg_sum_result 
----------------
 t
(1 row)

-- 2.3 AVG: average score
SELECT count(*) = 1 AS agg_avg_result
FROM pg_ripple.sparql($$
    SELECT (AVG(?score) AS ?avg) WHERE {
        ?s <https://w3c.sparql.query.test/score> ?score .
    }
$$);
 agg_avg_result 
----------------
 t
(1 row)

-- 2.4 MIN/MAX
SELECT count(*) = 1 AS agg_min_max
FROM pg_ripple.sparql($$
    SELECT (MIN(?score) AS ?lo) (MAX(?score) AS ?hi) WHERE {
        ?s <https://w3c.sparql.query.test/score> ?score .
    }
$$);
 agg_min_max 
-------------
 t
(1 row)

-- 2.5 GROUP BY: count of scores per score bucket (trivial grouping)
SELECT count(*) >= 1 AS agg_group_by
FROM pg_ripple.sparql($$
    SELECT ?s (COUNT(?score) AS ?cnt) WHERE {
        ?s <https://w3c.sparql.query.test/score> ?score .
    }
    GROUP BY ?s
$$);
 agg_group_by 
--------------
 t
(1 row)

-- 2.6 HAVING: persons with score > 75 (group by both ?s and ?score for compatibility)
SELECT count(*) = 2 AS agg_having
FROM pg_ripple.sparql($$
    SELECT ?s ?score WHERE {
        ?s <https://w3c.sparql.query.test/score> ?score .
    }
    GROUP BY ?s ?score
    HAVING (?score > 75)
$$);
 agg_having 
------------
 t
(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 3. Property Paths
-- ══════════════════════════════════════════════════════════════════════════════
-- 3.1 Zero-or-more (*): all nodes reachable via knows*
SELECT count(*) >= 3 AS path_zero_or_more
FROM pg_ripple.sparql($$
    SELECT ?target WHERE {
        <https://w3c.sparql.query.test/alice>
            <https://w3c.sparql.query.test/knows>* ?target .
    }
$$);
 path_zero_or_more 
-------------------
 t
(1 row)

-- 3.2 One-or-more (+): all nodes reachable via knows+
SELECT count(*) >= 3 AS path_one_or_more
FROM pg_ripple.sparql($$
    SELECT DISTINCT ?target WHERE {
        <https://w3c.sparql.query.test/alice>
            <https://w3c.sparql.query.test/knows>+ ?target .
    }
$$);
 path_one_or_more 
------------------
 t
(1 row)

-- 3.3 Inverse path (^): who does alice know? (who knows alice via ^knows)
SELECT count(*) = 1 AS path_inverse
FROM pg_ripple.sparql($$
    SELECT ?who WHERE {
        <https://w3c.sparql.query.test/alice>
            ^<https://w3c.sparql.query.test/knows> ?who .
    }
$$);
 path_inverse 
--------------
 t
(1 row)

-- 3.4 Sequence path (/): alice knows someone who knows ?x
SELECT count(*) >= 1 AS path_sequence
FROM pg_ripple.sparql($$
    SELECT DISTINCT ?x WHERE {
        <https://w3c.sparql.query.test/alice>
            <https://w3c.sparql.query.test/knows> /
            <https://w3c.sparql.query.test/knows> ?x .
    }
$$);
 path_sequence 
---------------
 t
(1 row)

-- 3.5 Alternative path (|): knows or type
SELECT count(*) >= 3 AS path_alternative
FROM pg_ripple.sparql($$
    SELECT DISTINCT ?s ?o WHERE {
        ?s (<https://w3c.sparql.query.test/knows> |
            <https://w3c.sparql.query.test/type>) ?o .
    }
$$);
 path_alternative 
------------------
 t
(1 row)

-- 3.6 Optional path (?): zero-or-one hop
SELECT count(*) >= 1 AS path_optional_hop
FROM pg_ripple.sparql($$
    SELECT DISTINCT ?x WHERE {
        <https://w3c.sparql.query.test/alice>
            <https://w3c.sparql.query.test/knows>? ?x .
    }
$$);
 path_optional_hop 
-------------------
 t
(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 4. UNION and Subqueries
-- ══════════════════════════════════════════════════════════════════════════════
-- 4.1 UNION: persons with name "Alice" OR "Bob"
SELECT count(*) = 2 AS union_alice_or_bob
FROM pg_ripple.sparql($$
    SELECT ?s WHERE {
        { ?s <https://w3c.sparql.query.test/name> "Alice" . }
        UNION
        { ?s <https://w3c.sparql.query.test/name> "Bob" . }
    }
$$);
 union_alice_or_bob 
--------------------
 t
(1 row)

-- 4.2 Subquery with LIMIT: inner query narrows to top-1
SELECT count(*) = 1 AS subquery_inner_limit
FROM pg_ripple.sparql($$
    SELECT ?s ?name WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
        {
            SELECT ?s WHERE {
                ?s <https://w3c.sparql.query.test/type>
                   <https://w3c.sparql.query.test/Person> .
            }
            ORDER BY ?s
            LIMIT 1
        }
    }
$$);
 subquery_inner_limit 
----------------------
 t
(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 5. BIND and VALUES
-- ══════════════════════════════════════════════════════════════════════════════
-- 5.1 BIND: compute doubled score
SELECT count(*) = 3 AS bind_doubled_score
FROM pg_ripple.sparql($$
    SELECT ?s ?double WHERE {
        ?s <https://w3c.sparql.query.test/score> ?score .
        BIND (?score * 2 AS ?double)
    }
$$);
 bind_doubled_score 
--------------------
 t
(1 row)

-- 5.2 VALUES: inject a lookup set
SELECT count(*) = 2 AS values_inline
FROM pg_ripple.sparql($$
    SELECT ?s ?name WHERE {
        VALUES ?s {
            <https://w3c.sparql.query.test/alice>
            <https://w3c.sparql.query.test/bob>
        }
        ?s <https://w3c.sparql.query.test/name> ?name .
    }
$$);
 values_inline 
---------------
 t
(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 6. Built-in Functions
-- ══════════════════════════════════════════════════════════════════════════════
-- 6.1 STR() — coerce any term to string
SELECT count(*) = 3 AS fn_str
FROM pg_ripple.sparql($$
    SELECT (STR(?age) AS ?age_str) WHERE {
        ?s <https://w3c.sparql.query.test/age> ?age .
    }
$$);
 fn_str 
--------
 t
(1 row)

-- 6.2 STRLEN() — string length
SELECT count(*) = 1 AS fn_strlen
FROM pg_ripple.sparql($$
    SELECT (STRLEN("Alice") AS ?len) WHERE {}
$$);
 fn_strlen 
-----------
 t
(1 row)

-- 6.3 UCASE / LCASE
SELECT count(*) = 3 AS fn_ucase_lcase
FROM pg_ripple.sparql($$
    SELECT (UCASE(?name) AS ?up) (LCASE(?name) AS ?down) WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
    }
$$);
 fn_ucase_lcase 
----------------
 t
(1 row)

-- 6.4 CONTAINS / STRSTARTS / STRENDS
SELECT count(*) = 1 AS fn_string_predicates
FROM pg_ripple.sparql($$
    SELECT ?name WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
        FILTER (CONTAINS(?name, "li") && STRSTARTS(?name, "Al") && STRENDS(?name, "ce"))
    }
$$);
 fn_string_predicates 
----------------------
 t
(1 row)

-- 6.5 REGEX
SELECT count(*) = 2 AS fn_regex
FROM pg_ripple.sparql($$
    SELECT ?name WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
        FILTER (REGEX(?name, "^[AB]"))
    }
$$);
 fn_regex 
----------
 t
(1 row)

-- 6.6 ABS / CEIL / FLOOR / ROUND on integer
SELECT count(*) = 1 AS fn_numeric
FROM pg_ripple.sparql($$
    SELECT (ABS(-30) AS ?a) (CEIL(2.1) AS ?c) (FLOOR(2.9) AS ?f) (ROUND(2.5) AS ?r)
    WHERE {}
$$);
 fn_numeric 
------------
 t
(1 row)

-- 6.7 IF()
SELECT count(*) = 3 AS fn_if
FROM pg_ripple.sparql($$
    SELECT (IF(?age > 28, "senior", "junior") AS ?tier) WHERE {
        ?s <https://w3c.sparql.query.test/age> ?age .
    }
$$);
 fn_if 
-------
 t
(1 row)

-- 6.8 COALESCE() — returns first non-error value
SELECT count(*) = 3 AS fn_coalesce
FROM pg_ripple.sparql($$
    SELECT (COALESCE(?email, "unknown") AS ?contact) WHERE {
        ?s <https://w3c.sparql.query.test/name> ?name .
        OPTIONAL { ?s <https://w3c.sparql.query.test/email> ?email . }
    }
$$);
 fn_coalesce 
-------------
 t
(1 row)

