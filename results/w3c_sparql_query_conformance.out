(1 row)

-- ══════════════════════════════════════════════════════════════════════════════
-- 11. Known Limitations (execute without error, results may be 0)
-- ══════════════════════════════════════════════════════════════════════════════
-- 11.1 langMatches() is not supported; executes without error returning 0 rows.
--      (Full language tag matching per BCP 47 is a known limitation.)
SELECT count(*) >= 0 AS lang_matches_no_error
FROM pg_ripple.sparql($$
    SELECT ?l WHERE {
        ?s <https://w3c.sparql.query.test/lang> ?l .
        FILTER (langMatches(LANG(?l), "fr"))
    }
$$);
 lang_matches_no_error 
-----------------------
 t
(1 row)

-- 11.2 Custom aggregate extensions (property functions) not supported;
--      standard aggregates work (verified above in section 2).
SELECT count(*) >= 0 AS custom_agg_graceful
FROM pg_ripple.sparql($$
    SELECT (COUNT(?s) AS ?n) WHERE {
        ?s <https://w3c.sparql.query.test/type>
           <https://w3c.sparql.query.test/Person> .
    }
$$);
 custom_agg_graceful 
---------------------
 t
(1 row)

