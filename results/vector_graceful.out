-- pg_regress test: pgvector_enabled = false graceful degradation (v0.27.0)
-- Verifies that setting pg_ripple.pgvector_enabled = off causes:
--   - store_embedding() to emit a WARNING and return
--   - similar_entities() to return zero rows (no ERROR)
--   - embed_entities() to return 0 (no ERROR)
-- This test works regardless of whether pgvector is installed.
SET client_min_messages = warning;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SET client_min_messages = DEFAULT;
SET search_path TO pg_ripple, public;
-- ── Disable pgvector integration ──────────────────────────────────────────────
SET pg_ripple.pgvector_enabled = off;
-- ── store_embedding() must not raise ERROR ────────────────────────────────────
SET client_min_messages = warning;
SELECT pg_ripple.store_embedding(
    'https://example.org/test',
    ARRAY[0.1, 0.2, 0.3]::float8[]
) IS NULL AS store_embedding_void_when_disabled;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
WARNING:  pg_ripple.store_embedding: pgvector disabled (pg_ripple.pgvector_enabled = false); returning empty results
 store_embedding_void_when_disabled 
------------------------------------
 f
(1 row)

SET client_min_messages = DEFAULT;
-- ── similar_entities() must return zero rows ──────────────────────────────────
SELECT count(*) = 0 AS similar_entities_empty_when_disabled
FROM pg_ripple.similar_entities('test query');
WARNING:  pg_ripple.similar_entities: pgvector disabled (pg_ripple.pgvector_enabled = false); returning empty results
 similar_entities_empty_when_disabled 
--------------------------------------
 t
(1 row)

-- ── embed_entities() must return 0 ───────────────────────────────────────────
SELECT pg_ripple.embed_entities() = 0 AS embed_entities_zero_when_disabled;
WARNING:  pg_ripple.embed_entities: pgvector disabled (pg_ripple.pgvector_enabled = false); returning empty results
 embed_entities_zero_when_disabled 
-----------------------------------
 t
(1 row)

-- ── refresh_embeddings() must return 0 ───────────────────────────────────────
SELECT pg_ripple.refresh_embeddings() = 0 AS refresh_embeddings_zero_when_disabled;
WARNING:  pg_ripple.refresh_embeddings: pgvector disabled (pg_ripple.pgvector_enabled = false); returning empty results
 refresh_embeddings_zero_when_disabled 
---------------------------------------
 t
(1 row)

-- ── Re-enable pgvector integration ───────────────────────────────────────────
RESET pg_ripple.pgvector_enabled;
-- Confirm the GUC is back to its default (on).
SELECT current_setting('pg_ripple.pgvector_enabled') AS pgvector_enabled_after_reset;
 pgvector_enabled_after_reset 
------------------------------
 on
(1 row)

