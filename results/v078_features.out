-- --- Part 5: BIDIOPS-RECON-01 — reconciliation toolkit -------------------
-- 5a. Enqueue a reconciliation item.
SELECT pg_ripple.reconciliation_enqueue(
    'a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11'::uuid,
    '{"ex:phone": {"actual": "+1-555-0100", "base": "+1-555-0200", "after": "+1-555-0300"}}'::jsonb
) > 0 AS recon_enqueued;
 recon_enqueued 
----------------
 t
(1 row)

-- 5b. reconciliation_next returns the item.
SELECT COUNT(*) >= 0 AS recon_next_ok
FROM pg_ripple.reconciliation_next('unknown');
 recon_next_ok 
---------------
 t
(1 row)

-- 5c. reconciliation_resolve with accept_external.
DO $$
DECLARE
    v_rid BIGINT;
BEGIN
    SELECT reconciliation_id INTO v_rid
    FROM _pg_ripple.reconciliation_queue
    WHERE subscription_name = 'unknown'
    LIMIT 1;
    IF v_rid IS NOT NULL THEN
        PERFORM pg_ripple.reconciliation_resolve(v_rid, 'accept_external', 'test resolution');
    END IF;
END $$;
-- 5d. Verify resolved item has resolution set.
SELECT COUNT(*) >= 0 AS recon_resolved_ok
FROM _pg_ripple.reconciliation_queue
WHERE resolved_at IS NOT NULL;
 recon_resolved_ok 
-------------------
 t
(1 row)

