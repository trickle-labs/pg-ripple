-- pg_regress test: v0.78.0 feature gate
--   BIDIOPS-QUEUE-01:  list_dead_letters / requeue_dead_letter / drop_dead_letter
--   BIDIOPS-EVOLVE-01: alter_subscription (schema evolution policies)
--   BIDIOPS-AUTH-01:   register_subscription_token / revoke_subscription_token / list_subscription_tokens
--   BIDIOPS-RECON-01:  reconciliation_enqueue / reconciliation_next / reconciliation_resolve
--   BIDIOPS-DASH-01:   bidi_status / bidi_health
--   BIDIOPS-AUDIT-01:  purge_event_audit
--   BIDIOPS-MIG-01:    schema presence checks
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SELECT pg_ripple.triple_count() >= 0 AS library_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 library_loaded 
----------------
 t
(1 row)

SET search_path TO pg_ripple, public;
-- --- Part 1: Schema presence checks (BIDIOPS-MIG-01) --------------------
-- 1a. event_dead_letters table exists.
SELECT COUNT(*) = 1 AS event_dead_letters_table_exists
FROM information_schema.tables
WHERE table_schema = '_pg_ripple'
  AND table_name = 'event_dead_letters';
 event_dead_letters_table_exists 
---------------------------------
 t
(1 row)

