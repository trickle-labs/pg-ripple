-- --- Part 2: BIDIOPS-AUTH-01 — subscription tokens -----------------------
-- 2a. Create a subscription first (needed for token registration).
SELECT pg_ripple.create_subscription('v078_test_sub') AS sub_created;
 sub_created 
-------------
 t
(1 row)

-- 2b. Register a token with default scopes.
SELECT LENGTH(pg_ripple.register_subscription_token('v078_test_sub')) > 10
    AS token_registered;
 token_registered 
------------------
 t
(1 row)

-- 2c. Token appears in list_subscription_tokens.
SELECT COUNT(*) >= 1 AS token_listed
FROM pg_ripple.list_subscription_tokens('v078_test_sub');
 token_listed 
--------------
 t
(1 row)

-- 2d. Register a token with explicit scopes and label.
SELECT LENGTH(
    pg_ripple.register_subscription_token(
        'v078_test_sub',
        ARRAY['linkback', 'divergence'],
        'test-relay'
    )
) > 10 AS scoped_token_registered;
 scoped_token_registered 
-------------------------
 t
(1 row)

-- 2e. Revoke the most recently registered token.
DO $$
DECLARE
    v_hash BYTEA;
BEGIN
    SELECT token_hash INTO v_hash
    FROM _pg_ripple.subscription_tokens
    WHERE subscription_name = 'v078_test_sub'
    ORDER BY created_at DESC
    LIMIT 1;
    PERFORM pg_ripple.revoke_subscription_token(v_hash);
END $$;
-- 2f. Revoked token has revoked_at set.
SELECT COUNT(*) >= 1 AS token_revoked
FROM _pg_ripple.subscription_tokens
WHERE subscription_name = 'v078_test_sub'
  AND revoked_at IS NOT NULL;
 token_revoked 
---------------
 t
(1 row)

-- --- Part 3: BIDIOPS-QUEUE-01 — dead-letter management -------------------
-- 3a. list_dead_letters returns 0 rows when empty.
SELECT COUNT(*) = 0 AS dead_letters_empty
FROM pg_ripple.list_dead_letters('v078_test_sub');
 dead_letters_empty 
--------------------
 t
(1 row)

-- 3b. Insert a dead-letter row directly to test the API.
INSERT INTO _pg_ripple.event_dead_letters
    (event_id, subscription_name, outbox_table, payload, emitted_at, reason)
VALUES
    (gen_random_uuid(), 'v078_test_sub', 'test_outbox',
     '{"test": true}'::jsonb, now() - interval '1 hour', 'queue_overflow');
-- 3c. list_dead_letters returns 1 row.
SELECT COUNT(*) = 1 AS dead_letter_present
FROM pg_ripple.list_dead_letters('v078_test_sub');
 dead_letter_present 
---------------------
 t
(1 row)

-- 3d. drop_dead_letter removes the row.
DO $$
DECLARE
    v_eid UUID;
BEGIN
    SELECT event_id INTO v_eid
    FROM _pg_ripple.event_dead_letters
    WHERE subscription_name = 'v078_test_sub'
    LIMIT 1;
    PERFORM pg_ripple.drop_dead_letter('v078_test_sub', 'test_outbox', v_eid);
END $$;
SELECT COUNT(*) = 0 AS dead_letter_dropped
FROM pg_ripple.list_dead_letters('v078_test_sub');
 dead_letter_dropped 
---------------------
 t
(1 row)

