-- --- Part 9: BIDIOPS-REDACT-01 — apply_frame_redaction -------------------
-- 9a. Redacted predicate replaced with {"@redacted": true}.
SELECT (pg_ripple.apply_frame_redaction(
    '{"ex:name": {}, "ex:phone": {"@redact": true}}'::jsonb,
    '{"@id": "ex:alice", "ex:name": "Alice", "ex:phone": "+1-555-0100"}'::jsonb
) ->> 'ex:phone') = '{"@redacted":true}'::jsonb::text AS phone_redacted;
 phone_redacted 
----------------
 t
(1 row)

-- 9b. Non-redacted predicate passes through unchanged.
SELECT (pg_ripple.apply_frame_redaction(
    '{"ex:name": {}, "ex:phone": {"@redact": true}}'::jsonb,
    '{"@id": "ex:alice", "ex:name": "Alice", "ex:phone": "+1-555-0100"}'::jsonb
) ->> 'ex:name') = 'Alice' AS name_unchanged;
 name_unchanged 
----------------
 t
(1 row)

-- 9c. Predicate not in payload is absent from result.
SELECT (pg_ripple.apply_frame_redaction(
    '{"ex:ssn": {"@redact": true}}'::jsonb,
    '{"@id": "ex:alice", "ex:name": "Alice"}'::jsonb
) -> 'ex:ssn') IS NULL AS missing_pred_absent;
 missing_pred_absent 
---------------------
 t
(1 row)

