-- 1g. subscriptions table has new columns.
SELECT COUNT(*) = 6 AS subscriptions_new_cols
FROM information_schema.columns
WHERE table_schema = '_pg_ripple'
  AND table_name = 'subscriptions'
  AND column_name IN (
      'max_queue_depth',
      'dead_letter_after',
      'overflow_policy',
      'frame_change_policy',
      'iri_change_policy',
      'exclude_change_policy'
  );
