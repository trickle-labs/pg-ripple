-- sparql_cursor.sql — Streaming cursor API tests (v0.40.0)
--
-- Verifies that:
--   1. sparql_cursor() exists and returns SETOF JSONB
--   2. sparql_cursor_turtle() exists and returns SETOF TEXT
--   3. sparql_cursor_jsonld() exists and returns SETOF TEXT
--   4. GUC pg_ripple.sparql_max_rows and pg_ripple.export_max_rows exist
--   5. sparql_overflow_action GUC exists
--   6. Cursor returns same results as sparql()
SET search_path TO pg_ripple, public;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
-- ── Setup ─────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_ntriples($$
<https://cursor.test/s1> <https://cursor.test/name>  "Item One" .
<https://cursor.test/s1> <https://cursor.test/value> "100"^^<http://www.w3.org/2001/XMLSchema#integer> .
<https://cursor.test/s2> <https://cursor.test/name>  "Item Two" .
<https://cursor.test/s2> <https://cursor.test/value> "200"^^<http://www.w3.org/2001/XMLSchema#integer> .
<https://cursor.test/s3> <https://cursor.test/name>  "Item Three" .
$$) = 5 AS triples_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 triples_loaded 
----------------
 t
(1 row)

-- ── 1. GUC checks ─────────────────────────────────────────────────────────────
-- 1a. sparql_max_rows defaults to 0 (unlimited).
SHOW pg_ripple.sparql_max_rows;
 pg_ripple.sparql_max_rows 
---------------------------
 0
(1 row)

-- 1b. export_max_rows defaults to 0 (unlimited).
SHOW pg_ripple.export_max_rows;
 pg_ripple.export_max_rows 
---------------------------
 0
(1 row)

-- 1c. sparql_overflow_action GUC exists.
SELECT count(*) = 1 AS overflow_action_guc_exists
FROM pg_settings WHERE name = 'pg_ripple.sparql_overflow_action';
 overflow_action_guc_exists 
----------------------------
 t
(1 row)

-- 1d. Can set and restore sparql_max_rows.
SET pg_ripple.sparql_max_rows = 10;
SHOW pg_ripple.sparql_max_rows;
 pg_ripple.sparql_max_rows 
---------------------------
 10
(1 row)

SET pg_ripple.sparql_max_rows = 0;
SHOW pg_ripple.sparql_max_rows;
 pg_ripple.sparql_max_rows 
---------------------------
 0
(1 row)

-- ── 2. sparql_cursor() SETOF JSONB ────────────────────────────────────────────
-- 2a. Returns at least 1 row.
SELECT count(*) >= 1 AS cursor_returns_rows
FROM pg_ripple.sparql_cursor($$
    SELECT ?s ?name WHERE { ?s <https://cursor.test/name> ?name }
$$);
 cursor_returns_rows 
---------------------
 t
(1 row)

-- 2b. Returns same count as sparql().
SELECT
    (SELECT count(*) FROM pg_ripple.sparql_cursor('SELECT ?s ?name WHERE { ?s <https://cursor.test/name> ?name }')) =
    (SELECT count(*) FROM pg_ripple.sparql('SELECT ?s ?name WHERE { ?s <https://cursor.test/name> ?name }'))
    AS cursor_matches_sparql_count;
 cursor_matches_sparql_count 
-----------------------------
 t
(1 row)

-- 2c. Each row is a valid JSONB object.
SELECT bool_and(jsonb_typeof(result) = 'object') AS all_rows_are_objects
FROM pg_ripple.sparql_cursor($$
    SELECT ?s ?name WHERE { ?s <https://cursor.test/name> ?name }
$$);
 all_rows_are_objects 
----------------------
 t
(1 row)

-- ── 3. sparql_cursor_turtle() SETOF TEXT ──────────────────────────────────────
-- 3a. Returns at least 1 row (batches of Turtle chunks).
SELECT count(*) >= 1 AS turtle_cursor_returns_rows
FROM pg_ripple.sparql_cursor_turtle($$
    CONSTRUCT { ?s <https://cursor.test/name> ?name }
    WHERE { ?s <https://cursor.test/name> ?name }
$$);
 turtle_cursor_returns_rows 
----------------------------
 t
(1 row)

-- 3b. Each row is non-empty text.
SELECT bool_and(length(chunk) > 0) AS all_turtle_rows_nonempty
FROM pg_ripple.sparql_cursor_turtle($$
    CONSTRUCT { ?s <https://cursor.test/name> ?name }
    WHERE { ?s <https://cursor.test/name> ?name }
$$);
 all_turtle_rows_nonempty 
--------------------------
 t
(1 row)

-- ── 4. sparql_cursor_jsonld() SETOF TEXT ──────────────────────────────────────
-- 4a. Returns at least 1 row.
SELECT count(*) >= 1 AS jsonld_cursor_returns_rows
FROM pg_ripple.sparql_cursor_jsonld($$
    CONSTRUCT { ?s <https://cursor.test/name> ?name }
    WHERE { ?s <https://cursor.test/name> ?name }
$$);
 jsonld_cursor_returns_rows 
----------------------------
 t
(1 row)

-- 4b. Content is non-empty text.
SELECT bool_and(length(chunk) > 0) AS all_jsonld_rows_nonempty
FROM pg_ripple.sparql_cursor_jsonld($$
    CONSTRUCT { ?s <https://cursor.test/name> ?name }
    WHERE { ?s <https://cursor.test/name> ?name }
$$);
 all_jsonld_rows_nonempty 
--------------------------
 t
(1 row)

