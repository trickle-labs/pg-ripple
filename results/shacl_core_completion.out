-- ─────────────────────────────────────────────────────────────────────────────
-- 3.  sh:languageIn — literal must have a language from the given list
-- ─────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <http://shacl.core23.test/> .

ex:LangShape
    a sh:NodeShape ;
    sh:targetClass ex:Article ;
    sh:property [
        sh:path ex:title ;
        sh:languageIn ( "en" "de" ) ;
    ] .
$SHACL$);
 load_shacl 
------------
          1
(1 row)

