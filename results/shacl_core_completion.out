-- ─────────────────────────────────────────────────────────────────────────────
-- 4.  sh:uniqueLang — no two values for the property may share a language tag
-- ─────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_shacl($SHACL$
@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ex:  <http://shacl.core23.test/> .

ex:UniqueLangShape
    a sh:NodeShape ;
    sh:targetClass ex:Concept ;
    sh:property [
        sh:path ex:label ;
        sh:uniqueLang true ;
    ] .
$SHACL$);
 load_shacl 
------------
          1
(1 row)

