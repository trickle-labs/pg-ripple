(1 row)

-- ex:plainBook has plain literals without lang tags → uniqueLang does NOT apply
SELECT pg_ripple.insert_triple(
    '<https://ex.org/ulang/plainBook>',
    '<https://ex.org/ulang/title>',
    '"Graph X"'
) > 0 AS t5;
 t5 
