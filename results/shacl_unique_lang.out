(1 row)

SELECT pg_ripple.insert_triple(
    '<https://ex.org/ulang/plainBook>',
    '<https://ex.org/ulang/title>',
    '"Graph X"'
) > 0 AS t6;
 t6 
----
 f
(1 row)

-- ── Shape ─────────────────────────────────────────────────────────────────────
DO $shapes$
DECLARE
  shapes_ttl TEXT := $ttl$
    @prefix sh: <http://www.w3.org/ns/shacl#> .
    @prefix ex: <https://ex.org/ulang/> .

    ex:UniqueLangShape
        a sh:NodeShape ;
        sh:targetNode ex:goodBook, ex:badBook, ex:plainBook ;
        sh:property [
            sh:path ex:title ;
            sh:uniqueLang true
        ] .
  $ttl$;
BEGIN
  PERFORM pg_ripple.load_turtle(shapes_ttl);
END
$shapes$;
-- ── Test 1: passing — distinct language tags ───────────────────────────────────
SELECT count(*) = 0 AS ulang_good_no_violations
FROM jsonb_array_elements(
    pg_ripple.validate_graph(
        'https://ex.org/ulang/UniqueLangShape'
    )
) v
WHERE v->>'focusNode' LIKE '%goodBook%';
ERROR:  function pg_ripple.validate_graph(unknown) does not exist at character 80
-- ── Test 2: failing — duplicate language tag ──────────────────────────────────
SELECT count(*) >= 1 AS ulang_bad_has_violation
FROM jsonb_array_elements(
    pg_ripple.validate_graph(
        'https://ex.org/ulang/UniqueLangShape'
    )
) v
WHERE v->>'focusNode' LIKE '%badBook%';
ERROR:  function pg_ripple.validate_graph(unknown) does not exist at character 80
-- ── Test 3: plain literals don't violate uniqueLang ───────────────────────────
SELECT count(*) = 0 AS ulang_plain_no_violations
FROM jsonb_array_elements(
    pg_ripple.validate_graph(
        'https://ex.org/ulang/UniqueLangShape'
    )
) v
WHERE v->>'focusNode' LIKE '%plainBook%';
ERROR:  function pg_ripple.validate_graph(unknown) does not exist at character 81
-- ── Cleanup ───────────────────────────────────────────────────────────────────
SELECT pg_ripple.drop_triples_by_graph(NULL) >= 0 AS cleaned;
ERROR:  function pg_ripple.drop_triples_by_graph(unknown) does not exist at character 8
