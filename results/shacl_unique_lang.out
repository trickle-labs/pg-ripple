-- pg_regress test: sh:uniqueLang constraint (v0.47.0)
--
-- Covers:
-- 1. Passing shape: all language tags on a property are distinct.
-- 2. Failing shape: duplicate language tag triggers violation.
-- 3. Plain literals (no lang tag) are not subject to uniqueLang.
SET client_min_messages = WARNING;
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SELECT pg_ripple.triple_count() >= 0 AS library_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 library_loaded 
----------------
 t
(1 row)

SET search_path TO pg_ripple, public;
-- ── Setup ─────────────────────────────────────────────────────────────────────
-- ex:goodBook has label in different languages → passes uniqueLang
SELECT pg_ripple.insert_triple(
    '<https://ex.org/ulang/goodBook>',
    '<https://ex.org/ulang/title>',
    '"Knowledge Graph"@en'
) > 0 AS t1;
 t1 
----
 t
(1 row)

SELECT pg_ripple.insert_triple(
    '<https://ex.org/ulang/goodBook>',
    '<https://ex.org/ulang/title>',
    '"Wissensgraph"@de'
) > 0 AS t2;
 t2 
----
 t
(1 row)

-- ex:badBook has two English labels → violates uniqueLang
SELECT pg_ripple.insert_triple(
    '<https://ex.org/ulang/badBook>',
    '<https://ex.org/ulang/title>',
    '"Graph A"@en'
) > 0 AS t3;
 t3 
----
