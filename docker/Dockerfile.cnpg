# pg_ripple CloudNativePG Extension Image (v0.98.0)
#
# This is a minimal "extension volume" image for use with the CloudNativePG
# operator (CNP ≥ 1.24).  It contains only the compiled .so and SQL files
# for pg_ripple, pgvector, and PostGIS at the paths expected by CNP's
# extensionImages feature gate.
#
# Usage in a CloudNativePG Cluster manifest:
#
#   spec:
#     postgresql:
#       extensionImages:
#         - ghcr.io/grove/pg-ripple:0.98.0-cnpg
#
# See docs/src/operations/cloudnativepg.md for the full walkthrough.
#
# Published as: ghcr.io/grove/pg-ripple:0.98.0-cnpg

# ── Build stage ───────────────────────────────────────────────────────────────
FROM rust:1-bookworm AS builder

ARG PGRX_VERSION=0.18.0
ARG PGVECTOR_VERSION=0.7.4

RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends gnupg curl ca-certificates \
    && curl -fsSL https://www.postgresql.org/media/keys/ACCC4CF8.asc \
       | gpg --dearmor -o /usr/share/keyrings/postgresql.gpg \
    && echo "deb [signed-by=/usr/share/keyrings/postgresql.gpg] \
https://apt.postgresql.org/pub/repos/apt bookworm-pgdg main" \
       > /etc/apt/sources.list.d/pgdg.list \
    && apt-get update -qq \
    && apt-get install -y --no-install-recommends \
       build-essential \
       pkg-config \
       libssl-dev \
       libclang-dev \
       clang \
       libreadline-dev \
       libicu-dev \
       bison \
       flex \
       postgresql-server-dev-18 \
       git \
    && rm -rf /var/lib/apt/lists/*

RUN cargo install cargo-pgrx --version "=${PGRX_VERSION}" --locked

WORKDIR /build

COPY Cargo.toml Cargo.lock build.rs pg_ripple.control ./
COPY src/   ./src/
COPY sql/   ./sql/
COPY pg_ripple_http/ ./pg_ripple_http/

RUN cargo pgrx init --pg18 /usr/lib/postgresql/18/bin/pg_config

RUN cargo pgrx package \
      --pg-config /usr/lib/postgresql/18/bin/pg_config \
      --features pg18

# Build pgvector
RUN git clone --depth 1 --branch "v${PGVECTOR_VERSION}" \
      https://github.com/pgvector/pgvector.git /tmp/pgvector \
    && cd /tmp/pgvector \
    && make PG_CONFIG=/usr/lib/postgresql/18/bin/pg_config \
    && make PG_CONFIG=/usr/lib/postgresql/18/bin/pg_config install

# ── Extension image stage ─────────────────────────────────────────────────────
# The extension image must contain files at the paths where CNP will bind-mount
# them into the PostgreSQL container.  The standard layout is:
#   /var/lib/postgresql/extension-files/lib/   → copied to $libdir/
#   /var/lib/postgresql/extension-files/ext/   → copied to $sharedir/extension/
#
# See: https://cloudnative-pg.io/documentation/current/extension_volumes/
FROM debian:bookworm-slim

ARG PG_VERSION=18

ENV EXTENSION_FILES_DIR=/var/lib/postgresql/extension-files

RUN mkdir -p \
    "${EXTENSION_FILES_DIR}/lib" \
    "${EXTENSION_FILES_DIR}/ext"

# pg_ripple
COPY --from=builder \
    /build/target/release/pg_ripple-pg18/usr/lib/postgresql/18/lib/pg_ripple.so \
    "${EXTENSION_FILES_DIR}/lib/"

COPY --from=builder \
    /build/target/release/pg_ripple-pg18/usr/share/postgresql/18/extension/ \
    "${EXTENSION_FILES_DIR}/ext/"

# pgvector
COPY --from=builder \
    /usr/lib/postgresql/18/lib/vector.so \
    "${EXTENSION_FILES_DIR}/lib/"

COPY --from=builder \
    /usr/share/postgresql/18/extension/vector* \
    "${EXTENSION_FILES_DIR}/ext/"

LABEL org.opencontainers.image.source="https://github.com/grove/pg-ripple"
LABEL org.opencontainers.image.description="CloudNativePG extension volume: pg_ripple + pgvector for PostgreSQL 18"
LABEL org.opencontainers.image.licenses="Apache-2.0"
LABEL org.opencontainers.image.version="0.98.0-cnpg"

# The image is used purely as an init-container volume source; no entrypoint needed.
CMD ["/bin/true"]
