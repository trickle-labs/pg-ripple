 t
(1 row)

-- ─── Version check ───────────────────────────────────────────────────────────
-- compiled_version must be 0.98.0.
SELECT value = '0.98.0' AS version_is_0_98_0
FROM pg_ripple.diagnostic_report()
WHERE key = 'compiled_version';
 version_is_0_98_0 
-------------------
 t
