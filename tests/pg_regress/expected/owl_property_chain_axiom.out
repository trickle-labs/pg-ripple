-- ────────────────────────────────────────────────────────────────────────────
-- Test 7: Verify no infinite loop when chain body includes same property
-- (cycle-safety: owl-rl stratification prevents unbounded recursion)
-- ────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_ntriples(
    '<https://pca.test/cycle/r> <https://pca.test/cycle/p> <https://pca.test/cycle/s> .'
) = 1 AS cycle_safety_triple_loaded;
 cycle_safety_triple_loaded 
----------------------------
 t
(1 row)

SELECT pg_ripple.infer('owl-rl') >= 0 AS cycle_safety_ran;
 cycle_safety_ran 
------------------
 t
(1 row)

-- After inference the system should still be alive (no infinite loop).
SELECT pg_ripple.triple_count() >= 37 AS cycle_safety_ok;
