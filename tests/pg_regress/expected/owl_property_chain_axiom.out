-- ────────────────────────────────────────────────────────────────────────────
-- Test 4: 3-hop chain (uncle: parent / parent / sibling)
-- ────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_ntriples(
    '<https://pca.test/family/dave>  <https://pca.test/family/parent>  <https://pca.test/family/ed> .' || E'\n' ||
    '<https://pca.test/family/ed>    <https://pca.test/family/parent>  <https://pca.test/family/frank> .' || E'\n' ||
    '<https://pca.test/family/frank> <https://pca.test/family/sibling> <https://pca.test/family/grace> .' || E'\n' ||
    '<https://pca.test/family/grandUncle> <http://www.w3.org/2002/07/owl#propertyChainAxiom> <https://pca.test/family/gu1> .' || E'\n' ||
    '<https://pca.test/family/gu1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <https://pca.test/family/parent> .' || E'\n' ||
    '<https://pca.test/family/gu1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/family/gu2> .' || E'\n' ||
    '<https://pca.test/family/gu2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <https://pca.test/family/parent> .' || E'\n' ||
    '<https://pca.test/family/gu2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/family/gu3> .' || E'\n' ||
    '<https://pca.test/family/gu3> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <https://pca.test/family/sibling> .' || E'\n' ||
    '<https://pca.test/family/gu3> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .'
) = 10 AS family_chain_triples_loaded;
