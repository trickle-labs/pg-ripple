    '<https://pca.test/foaf3/f1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://xmlns.com/foaf/0.1/knows> .' || E'\n' ||
    '<https://pca.test/foaf3/f1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/foaf3/f2> .' || E'\n' ||
    '<https://pca.test/foaf3/f2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://xmlns.com/foaf/0.1/knows> .' || E'\n' ||
    '<https://pca.test/foaf3/f2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/foaf3/f3> .' || E'\n' ||
    '<https://pca.test/foaf3/f3> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://xmlns.com/foaf/0.1/knows> .' || E'\n' ||
