-- ────────────────────────────────────────────────────────────────────────────
-- Test 3: PROV-O derivation chain
-- owl:propertyChainAxiom: prov:wasDerivedFrom2 := prov:wasGeneratedBy / prov:used
-- ────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_ntriples(
    '<https://pca.test/prov/D1> <http://www.w3.org/ns/prov#wasGeneratedBy> <https://pca.test/prov/A1> .' || E'\n' ||
    '<https://pca.test/prov/A1> <http://www.w3.org/ns/prov#used>            <https://pca.test/prov/E1> .' || E'\n' ||
    '<https://pca.test/prov/derivedFrom2> <http://www.w3.org/2002/07/owl#propertyChainAxiom> <https://pca.test/prov/p1> .' || E'\n' ||
    '<https://pca.test/prov/p1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://www.w3.org/ns/prov#wasGeneratedBy> .' || E'\n' ||
    '<https://pca.test/prov/p1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/prov/p2> .' || E'\n' ||
    '<https://pca.test/prov/p2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://www.w3.org/ns/prov#used> .' || E'\n' ||
    '<https://pca.test/prov/p2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .'
) = 7 AS prov_chain_triples_loaded;
 prov_chain_triples_loaded 
---------------------------
 t
(1 row)

SELECT pg_ripple.infer('owl-rl') >= 0 AS prov_chain_inferred;
 prov_chain_inferred 
