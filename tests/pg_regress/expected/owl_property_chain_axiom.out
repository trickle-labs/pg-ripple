-- pg_regress test: owl:propertyChainAxiom inference (Feature 5, v0.119.0)
-- 10 canonical tests: FOAF knows chain, SKOS broaderTransitive, PROV-O
-- derivation chains, and 7 additional chain scenarios.
CREATE EXTENSION IF NOT EXISTS pg_ripple;
SELECT pg_ripple.triple_count() >= 0 AS extension_loaded;
WARNING:  pg_ripple: loaded without shared_preload_libraries; HTAP merge worker, CONSTRUCT writeback, and dictionary cache are disabled. Add pg_ripple to shared_preload_libraries in postgresql.conf.
 extension_loaded 
------------------
 t
(1 row)

SET search_path TO pg_ripple, public;
-- Load OWL RL built-in rules.
SELECT pg_ripple.load_rules_builtin('owl-rl') >= 0 AS owl_rl_loaded;
 owl_rl_loaded 
---------------
 t
(1 row)

-- ────────────────────────────────────────────────────────────────────────────
-- Test 1: FOAF knows 2-hop chain
-- owl:propertyChainAxiom: foaf:knows2hop := foaf:knows / foaf:knows
-- ────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_ntriples(
    '<https://pca.test/foaf/alice> <http://xmlns.com/foaf/0.1/knows> <https://pca.test/foaf/bob> .' || E'\n' ||
    '<https://pca.test/foaf/bob>   <http://xmlns.com/foaf/0.1/knows> <https://pca.test/foaf/carol> .' || E'\n' ||
    '<https://pca.test/foaf/knows2hop> <http://www.w3.org/2002/07/owl#propertyChainAxiom> <https://pca.test/foaf/c1> .' || E'\n' ||
    '<https://pca.test/foaf/c1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://xmlns.com/foaf/0.1/knows> .' || E'\n' ||
    '<https://pca.test/foaf/c1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/foaf/c2> .' || E'\n' ||
    '<https://pca.test/foaf/c2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://xmlns.com/foaf/0.1/knows> .' || E'\n' ||
    '<https://pca.test/foaf/c2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .'
) = 7 AS foaf_chain_triples_loaded;
 foaf_chain_triples_loaded 
---------------------------
 t
(1 row)

SELECT pg_ripple.infer('owl-rl') >= 0 AS foaf_chain_inferred;
 foaf_chain_inferred 
---------------------
 t
(1 row)

-- After inference, total triple count should be at least 7.
SELECT pg_ripple.triple_count() >= 7 AS foaf_chain_test_ok;
 foaf_chain_test_ok 
--------------------
 t
(1 row)

-- ────────────────────────────────────────────────────────────────────────────
-- Test 2: SKOS broaderTransitive closure via 2-hop chain
-- owl:propertyChainAxiom: skos:broader2step := skos:broader / skos:broader
-- ────────────────────────────────────────────────────────────────────────────
SELECT pg_ripple.load_ntriples(
    '<https://pca.test/skos/Dog>    <http://www.w3.org/2004/02/skos/core#broader> <https://pca.test/skos/Animal> .' || E'\n' ||
    '<https://pca.test/skos/Animal> <http://www.w3.org/2004/02/skos/core#broader> <https://pca.test/skos/LivingThing> .' || E'\n' ||
    '<https://pca.test/skos/broader2step> <http://www.w3.org/2002/07/owl#propertyChainAxiom> <https://pca.test/skos/s1> .' || E'\n' ||
    '<https://pca.test/skos/s1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://www.w3.org/2004/02/skos/core#broader> .' || E'\n' ||
    '<https://pca.test/skos/s1> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <https://pca.test/skos/s2> .' || E'\n' ||
    '<https://pca.test/skos/s2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#first> <http://www.w3.org/2004/02/skos/core#broader> .' || E'\n' ||
    '<https://pca.test/skos/s2> <http://www.w3.org/1999/02/22-rdf-syntax-ns#rest>  <http://www.w3.org/1999/02/22-rdf-syntax-ns#nil> .'
) = 7 AS skos_chain_triples_loaded;
 skos_chain_triples_loaded 
---------------------------
 t
(1 row)

SELECT pg_ripple.infer('owl-rl') >= 0 AS skos_chain_inferred;
