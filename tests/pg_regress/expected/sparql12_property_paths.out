-- ─── Test 20: Bidirectional (hop|^hop)+ from c — all connected nodes ────────
-- Chain a-b-c-d-e-f fully bidirectional; from c via one or more steps:
-- {b, d} (1 hop), {a, c, e} (2 hops), {f} (3 hops) = 6 unique nodes.
-- Note: c itself is reachable in 2 steps (c→d→c via reverse), so count = 6.
SELECT COUNT(*) = 6 AS t20_bidirectional
FROM pg_ripple.sparql($$
    SELECT ?x WHERE {
        <https://sp12.test/c>
            (<https://sp12.test/hop>|^<https://sp12.test/hop>)+ ?x .
    }
$$);
 t20_bidirectional 
